# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=
DIRECT_URL=

# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── Seed-time credentials (never commit real values) ─────────────────────────
# These variables are used ONLY by `prisma db seed`.
# Set them in your local .env or pass them inline at seed time.
# If absent, the seed skips user/credential creation safely.
SEED_ADMIN_EMAIL=
SEED_ADMIN_NAME=
SEED_ADMIN_PASSWORD=
SEED_ARKETOPS_ADMIN_PASSWORD=
SEED_ARKETOPS_VIEWER_PASSWORD=
