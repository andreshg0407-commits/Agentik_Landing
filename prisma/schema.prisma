// Agentik schema
// Prisma 7 config-first setup
// ⚠️ DATABASE URL lives in prisma.config.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// --------------------
/// Enums
/// --------------------
enum OrgType {
  SAAS_CUSTOMER
  ENTERPRISE
  INTERNAL
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  PAUSED
  ARCHIVED
}

enum Role {
  SUPER_ADMIN    // Agentik superuser — overrides everything
  AGENTIK_ADMIN  // Agentik internal platform admin — Consola Interna only, no client data
  ORG_ADMIN      // Client org admin — fully client-facing, no internal console
  MANAGER
  OPERATOR
  VIEWER
  BILLING
}

enum MembershipStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum AgentType {
  MARKETING
  SALES
  WEB_MANAGER
  ACCOUNTING
  OPS
  CUSTOM
}

enum AgentStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ChannelType {
  WHATSAPP
  TIKTOK
  INSTAGRAM
  FACEBOOK
  WEB
  EMAIL
  API
}

enum IntegrationProvider {
  META
  TIKTOK
  GOOGLE
  SHOPIFY
  STRIPE
  ZELLE
  MERCURY
  DIAN
  PYA
  CUSTOM
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
}

enum WorkflowProvider {
  N8N
  CUSTOM
}

enum WorkflowStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum RunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum ConversationStatus {
  OPEN
  PENDING_HANDOFF
  HANDED_OFF
  CLOSED
}

enum MessageRole {
  USER
  AGENT
  TOOL
  SYSTEM
}

enum FilePurpose {
  CATALOG
  BRAND_ASSET
  DOCUMENT
  PROMPT_ATTACHMENT
  OTHER
}

enum PlanInterval {
  MONTH
  YEAR
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum SyncJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum RuleStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum RuleExecutionStatus {
  MATCHED
  SKIPPED
  FAILED
}

enum EventStatus {
  PENDING
  PROCESSED
  FAILED
}

enum UsageKind {
  LLM_TOKENS
  LLM_CALL
  IMAGE_GEN
  VIDEO_GEN
  STORAGE
  WORKFLOW_RUN
  MESSAGE
}

enum ActionTaskStatus {
  PENDING
  SCHEDULED
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

/// Lifecycle state of a CollectionRecord relative to invoice reconciliation.
enum CollectionAppliedStatus {
  AVAILABLE          // received from SAG, not yet linked to any invoice
  PARTIALLY_APPLIED  // partial amount applied to invoice(s); remainder open
  APPLIED            // fully applied — all amount allocated
  MANUAL_OVERRIDE    // operator marked as applied without a PaymentRecord
}

/// Where the real monetary amount in CollectionRecord came from.
/// SAG_V_PAGOSNEW is the primary confirmed source (Valor_Pagado).
enum CollectionAmountSource {
  SAG_V_PAGOSNEW    // v_pagosnew.Valor_Pagado — confirmed 2026-04-30
  SAG_V_MOVPAGOS    // v_movimientos_pagos_con_facturas (pending validation)
  SAG_V_DOCPAGOS    // v_documentos_pagos_detalle (pending validation)
  MANUAL            // manually entered by operator
}

enum ActionTaskType {
  CREAR_TAREA_COMERCIAL
  ASIGNAR_SEGUIMIENTO_VENDEDOR
  MARCAR_CLIENTE_RECUPERACION
  GENERAR_INFORME
  PROGRAMAR_INFORME
  ABRIR_ALERTA_OPERATIVA
  CREAR_ACCION_COBRANZA
  ESCALAR_A_GERENCIA
}

enum ActionTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

/// Lifecycle state of a reconciliation session.
/// Maps 1:1 to ReconciliationSessionStatus in lib/reconciliation/session-types.ts.
enum ReconSessionStatus {
  DRAFT
  READY
  RUNNING
  NEEDS_REVIEW
  PARTIALLY_RECONCILED
  RECONCILED
  CLOSED
  FAILED
  CANCELLED
}

enum NotificationType {
  ACTION_ASSIGNED
  ACTION_REASSIGNED
  ACTION_DUE_TODAY
  ACTION_OVERDUE
  ACTION_COMPLETED
  SCHEDULED_REPORT_READY
  SCHEDULED_REPORT_FAILED
  SYSTEM
}

enum ScheduleFrequency {
  ONCE
  WEEKLY
  MONTHLY
}

/// --------------------
/// Tenant / Identity
/// --------------------
model Organization {
  id     String    @id @default(cuid())
  name   String
  slug   String    @unique
  type   OrgType   @default(ENTERPRISE)
  status OrgStatus @default(ACTIVE)

  // Branding / preferences per org
  settingsJson Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  members         Membership[]
  workspaces      Workspace[]
  projects        Project[]
  agents          Agent[]
  channels        Channel[]
  integrations    Integration[]
  workflows       Workflow[]
  files           FileObject[]
  knowledge       KnowledgeItem[]
  runs            Run[]
  logs            AgentLog[]
  audits          AuditLog[]
  subscriptions   Subscription[]
  conversations   Conversation[]
  messages        Message[]
  usageEvents     UsageEvent[]
  events          Event[]
  rules           Rule[]
  alerts          Alert[]
  metricSnapshots  MetricSnapshot[]
  syncJobs         SyncJob[]
  documents        Document[]
  productSnapshots ProductSnapshot[]
  orderSnapshots   OrderSnapshot[]
  salesImportBatches  SalesImportBatch[]
  saleRecords         SaleRecord[]
  businessAlerts      BusinessAlert[]
  connectors          Connector[]
  customerProfiles    CustomerProfile[]
  customerReceivables CustomerReceivable[]
  paymentRecords      PaymentRecord[]
  crmOpportunities    CRMOpportunity[]
  crmActivities       CRMActivity[]
  crmQuotes           CRMQuote[]
  crmQuoteLines       CRMQuoteLine[]
  pipelineStages      PipelineStage[]
  sagWriteOperations  SagWriteOperation[]
  actionTasks         ActionTask[]
  notifications       Notification[]
  scheduledReports    ScheduledReport[]
  budgets             Budget[]
  tenantModules       TenantModule[]
  whatsAppConfig          WhatsAppConfig?
  whatsAppConversations   WhatsAppConversation[]
  whatsAppContactMemories WhatsAppContactMemory[]
  studioSessions          StudioSession[]
  customerOrderRecords    CustomerOrderRecord[]
  collectionRecords       CollectionRecord[]
  collectionAllocations   CollectionAllocation[]
  orgGroupMemberships     OrgGroupMember[]
  onboardingChecklist     OnboardingChecklist?
  marketingConfig         TenantMarketingConfig?
  reconciliationSessions    ReconciliationSession[]
  reconciliationRuns        ReconciliationRun[]
  reconciliationEvents      ReconciliationEvent[]
  reconciliationExceptions  ReconciliationException[]
  copilotSignals            CopilotSignalRecord[]
  copilotActions            CopilotActionLog[]
  productEntities           ProductEntity[]
  integrationConnections    IntegrationConnection[]
  integrationSecrets        IntegrationSecret[]
  integrationEvents         IntegrationEvent[]
  integrationWebhookEvents  IntegrationWebhookEvent[]
  commerceJobs              CommerceJob[]
  destinationHealthSnapshots DestinationHealthSnapshot[]
  executionRetryAttempts     ExecutionRetryAttempt[]
  distributionVariants       DistributionVariant[]
  distributionPipelines      DistributionPipeline[]
  distributionSchedules      DistributionSchedule[]
  publishingPlans            PublishingPlan[]
  publishingPlanSteps        PublishingPlanStep[]
  publishingEvents           PublishingEvent[]
  publishingHealthSnapshots  PublishingHealthSnapshot[]
  operatorReceipts           OperatorReceipt[]
  operatorAuditEvents        OperatorAuditEvent[]
  operatorHealthSnapshots    OperatorHealthSnapshot[]
  oauthSessions              OAuthSession[]
  bankAccounts               BankAccount[]
  bankMovements              BankMovement[]
  bankSyncSessions           BankSyncSession[]
  bankReconciliations        BankReconciliation[]
  bankStatementUploads         BankStatementUpload[]
  financialRuntimeSnapshots    FinancialRuntimeSnapshot[]
  financialRuntimeEvents       FinancialRuntimeEvent[]

  // ── Maletas Commercial ───────────────────────────────────────────────────
  commercialCases                    CommercialCase[]
  commercialCaseItems                CommercialCaseItem[]
  commercialCoverageSnapshots        CommercialCoverageSnapshot[]
  commercialOperationalEvents        CommercialOperationalEvent[]
  commercialProductionSignals        CommercialProductionSignal[]
  commercialDeadStockSignals         CommercialDeadStockSignal[]
  commercialSalesRepSnapshots        CommercialSalesRepProfileSnapshot[]
  vendorCommercialBags               VendorCommercialBag[]
  vendorBagItems                     VendorBagItem[]
  vendorBagOrderLines                VendorBagOrderLine[]

  // ── Operational Reservations ──────────────────────────────────────────────
  operationalReservations            OperationalReservation[]
  operationalReservationEvents       OperationalReservationEvent[]

  // ── Agent Runtime Execution ───────────────────────────────────────────────
  runtimeExecutionSessions           RuntimeExecutionSession[]

  // ── Operational KPI Certification ─────────────────────────────────────────
  operationalKpiCertifications       OperationalKpiCertification[]
  operationalKpiSources              OperationalKpiSource[]
  operationalKpiDefinitions          OperationalKpiDefinition[]
  operationalKpiEvents               OperationalKpiEvent[]
  operationalDataSources             OperationalDataSource[]

  // ── Reconciliation Rule Engine Executions ─────────────────────────────────
  reconExecutions                    ReconExecution[]
  reconReviewItems                   ReconReviewItem[]
  reconReviewAuditEvents             ReconReviewAuditEvent[]
  meetingAgreements                  MeetingAgreement[]
  tasks                              Task[]
  approvals                          Approval[]
  workExecutions                     WorkExecution[]
  workflowRuns                       WorkflowRun[]
  aiUsages                           AiUsage[]
  aiCreditLedger                     AiCreditLedger[]
  aiCreditBalance                    AiCreditBalance?

  @@index([status])
}

model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?
  phone String?

  // Auth.js v5 required fields
  emailVerified DateTime?
  image         String?

  // Auth strategy: password hash or oauth provider; keep flexible
  authJson Json?

  memberships          Membership[]
  auditLogs            AuditLog[]           @relation("UserAuditLogs")
  assignedAlerts       Alert[]              @relation("AssignedAlerts")
  // Auth.js relations
  accounts             Account[]
  sessions             Session[]
  passwordCredential   PasswordCredential?
  // Workspace-level access (multi-tenant)
  workspaceMemberships WorkspaceMembership[]
  uploadedDocuments    Document[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Membership {
  id             String @id @default(cuid())
  organizationId String
  userId         String
  role           Role   @default(VIEWER)

  status          MembershipStatus @default(INVITED)
  invitedAt       DateTime?
  acceptedAt      DateTime?
  disabledAt      DateTime?
  permissionsJson Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId, status])
}

/// --------------------
/// Projects (modules / initiatives)
/// --------------------
model Project {
  id             String        @id @default(cuid())
  organizationId String
  // Optional: scope this technical initiative to a brand/client workspace
  workspaceId    String?
  name           String
  key            String // REQUIRED stable key like "dojeans-control-center"
  status         ProjectStatus @default(PLANNED)
  description    String?
  settingsJson   Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  agents          Agent[]
  channels        Channel[]
  integrations    Integration[]
  workflows       Workflow[]
  knowledge       KnowledgeItem[]
  files           FileObject[]
  runs            Run[]
  audits          AuditLog[]
  projectModules  ProjectModule[]
  conversations   Conversation[]
  usageEvents     UsageEvent[]
  events          Event[]
  rules           Rule[]
  alerts          Alert[]
  metricSnapshots MetricSnapshot[]
  syncJobs        SyncJob[]
  logs            AgentLog[] // ✅ relación real para AgentLog (mejora producción)
  documents       Document[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // ✅ Esto es CLAVE: de aquí sale el unique input `organizationId_key` en Prisma (seed correcto)
  @@unique([organizationId, key])
  @@index([organizationId, status])
  @@index([key]) // (opcional) útil para búsquedas rápidas por key
  @@index([workspaceId])
}

/// Optional: which “modules” are enabled in a project (phased rollout)
model ProjectModule {
  id         String  @id @default(cuid())
  projectId  String
  // Examples: “CONTROL_CENTER”, “MILA_WHATSAPP”, “LUCA_MARKETING”, “DIAN_AUTOMATION”
  code       String
  enabled    Boolean @default(false)
  configJson Json?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, code])
  @@index([projectId, enabled])
}

/// Per-org feature flags for UI modules.
/// Open by default: if no row exists for a (org, moduleKey) pair the module is considered ENABLED.
/// Only explicit enabled=false rows hide modules.
/// Keys match the ModuleKey enum in lib/tenant/modules.ts.
model TenantModule {
  id             String  @id @default(cuid())
  organizationId String
  /// Canonical module key — see ModuleKey in lib/tenant/modules.ts
  moduleKey      String
  enabled        Boolean @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, moduleKey])
  @@index([organizationId, enabled])
}

// ── Tenant Group + Onboarding + Marketing Config ──────────────────────────────

/// Logical grouping of organizations (e.g. "Castillitos Group").
/// No business data lives here — it is a read-only aggregation context.
model OrgGroup {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  settingsJson Json?

  members   OrgGroupMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Membership of an Organization in an OrgGroup.
model OrgGroupMember {
  id        String @id @default(cuid())
  groupId   String
  orgId     String
  role      String @default("MEMBER")  // "MEMBER" | "LEAD"
  sortOrder Int    @default(0)

  group        OrgGroup     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId],   references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([groupId, orgId])
  @@index([orgId])
}

/// Activation checklist per organization.
/// Tracks onboarding progress — updated as each step completes.
/// All booleans default false; completedAt set when operator finishes.
model OnboardingChecklist {
  id             String  @id @default(cuid())
  organizationId String  @unique

  businessModeSet     Boolean @default(false)
  erpConnected        Boolean @default(false)
  erpSampleVerified   Boolean @default(false)
  erpFirstSyncDone    Boolean @default(false)
  shopifyConnected    Boolean @default(false)
  whatsappConnected   Boolean @default(false)
  socialConnected     Boolean @default(false)
  brandVoiceSet       Boolean @default(false)
  modulesActivated    Boolean @default(false)

  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

/// DB-backed Marketing Studio configuration per organization.
/// Replaces the hardcoded ALL_TENANT_CONFIGS array in tenant-config.ts.
/// configJson mirrors the TenantMarketingConfig TypeScript type (brandVoice,
/// allowedPresets, luca, categoryAliases, fotoEstudio, shopify, etc.).
model TenantMarketingConfig {
  id             String  @id @default(cuid())
  organizationId String  @unique
  tenantName     String
  active         Boolean @default(true)

  /// Prompt engine key used by foto-estudio generate route.
  /// "kids_product"   → buildCastillitosProductPrompt()
  /// "fashion_adult"  → buildDoJeansFashionPrompt()
  /// "generic"        → generic fallback (fashion_adult behavior)
  promptEngine   String  @default("generic")

  /// Full config blob — mirrors TenantMarketingConfig TS type.
  configJson     Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

/// --------------------
/// Agents (Luca, Mila, etc.)
/// --------------------
model Agent {
  id             String      @id @default(cuid())
  organizationId String
  projectId      String?
  name           String
  type           AgentType   @default(CUSTOM)
  status         AgentStatus @default(DRAFT)

  // Runtime selection
  modelProvider   String? // "anthropic", "openai", "google", etc.
  modelName       String? // "claude-...", "gpt-...", "gemini-..."
  temperature     Float?
  topP            Float?
  maxOutputTokens Int?

  // FIX: two relations Agent<->AgentVersion must be named + opposite fields exist
  versions AgentVersion[] @relation("AgentVersions")

  activeVersionId String?
  activeVersion   AgentVersion? @relation("ActiveAgentVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)

  // Freeform config (for quick start); recommended to use versions below
  configJson Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  channels       Channel[]
  conversations  Conversation[]
  logs           AgentLog[]
  runs           Run[]
  knowledgeLinks KnowledgeLink[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, name])
  @@index([organizationId, status])
  @@index([projectId])
}

model AgentVersion {
  id      String  @id @default(cuid())
  agentId String
  version Int
  label   String?

  // Prompting + policy + tools instructions
  systemPrompt String?
  policyJson   Json?
  toolsJson    Json?

  // Persona / style / forbidden words / sales rules / etc.
  behaviorJson Json?

  // Domain knowledge references: tags, categories, etc.
  metadataJson Json?

  agent Agent @relation("AgentVersions", fields: [agentId], references: [id], onDelete: Cascade)

  // Opposite side for activeVersion
  activeFor Agent[] @relation("ActiveAgentVersion")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agentId, version])
  @@index([agentId])
}

/// --------------------
/// Channels & Integrations
/// --------------------
model Channel {
  id             String  @id @default(cuid())
  organizationId String
  projectId      String?
  agentId        String?
  integrationId  String?

  type   ChannelType
  name   String? // e.g. "Mila WPP DoJeans"
  status String? // keep flexible (Meta statuses vary)

  // Phone/page/account identifiers depending on channel
  externalAccountId String?
  externalPhoneId   String?
  externalPageId    String?

  // Store secrets/credentials encrypted at app layer (prefer Integration.secretsJson in prod)
  credentialsJson Json?
  settingsJson    Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  agent        Agent?       @relation(fields: [agentId], references: [id], onDelete: SetNull)
  integration  Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  conversations Conversation[]
  runs          Run[]
  agentLogs     AgentLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId, type])
  @@index([projectId])
  @@index([agentId])
  @@index([integrationId])
}

model Integration {
  id             String              @id @default(cuid())
  organizationId String
  projectId      String?
  provider       IntegrationProvider
  name           String?

  status       IntegrationStatus @default(DISCONNECTED)
  lastSyncedAt DateTime?
  lastError    String?

  // OAuth tokens, API keys, endpoints, etc. (encrypted by app layer)
  secretsJson Json?
  // Non-sensitive settings/ids
  configJson  Json?
  metaJson    Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  channels Channel[]
  syncJobs SyncJob[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId, provider])
  @@index([projectId])
  @@index([organizationId, status])
}

/// --------------------
/// Workflows (n8n, custom) + Runs
/// --------------------
model Workflow {
  id             String           @id @default(cuid())
  organizationId String
  projectId      String?
  provider       WorkflowProvider @default(N8N)
  status         WorkflowStatus   @default(ACTIVE)

  name        String
  // For n8n: workflow ID, webhook URLs, etc.
  externalId  String?
  endpointUrl String?
  configJson  Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  runs Run[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId, status])
  @@index([projectId])
}

model Run {
  id             String  @id @default(cuid())
  organizationId String
  projectId      String?
  agentId        String?
  channelId      String?
  workflowId     String?
  conversationId String?

  // Job OS fields
  type        String   @default("generic") // e.g. "marketing.image_to_video"
  traceId     String?
  attempt     Int      @default(0)
  maxAttempts Int      @default(3)
  queuedAt    DateTime @default(now())

  status RunStatus @default(QUEUED)

  // Useful for idempotency / retries
  // ✅ Mantén NULL cuando no exista (no uses "" en app).
  idempotencyKey String?

  inputJson  Json?
  outputJson Json?
  errorJson  Json?

  startedAt DateTime?
  endedAt   DateTime?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  agent        Agent?        @relation(fields: [agentId], references: [id], onDelete: SetNull)
  channel      Channel?      @relation(fields: [channelId], references: [id], onDelete: SetNull)
  workflow     Workflow?     @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  logs   AgentLog[]
  events Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([projectId])
  @@index([agentId])
  @@index([workflowId])
  @@index([conversationId])
}

/// --------------------
/// Conversations (Mila) + Messages
/// --------------------
model Conversation {
  id             String             @id @default(cuid())
  organizationId String
  projectId      String?
  agentId        String?
  channelId      String?
  status         ConversationStatus @default(OPEN)

  // For WhatsApp: customer phone; for web: session id; etc.
  externalThreadId String?
  customerName     String?
  customerHandle   String? // phone/email/username
  metadataJson     Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  agent        Agent?       @relation(fields: [agentId], references: [id], onDelete: SetNull)
  channel      Channel?     @relation(fields: [channelId], references: [id], onDelete: SetNull)

  messages Message[]
  runs     Run[]
  logs     AgentLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime?

  @@index([organizationId, status])
  @@index([agentId])
  @@index([channelId])
  @@index([customerHandle])
}

model Message {
  id             String @id @default(cuid())
  organizationId String
  conversationId String

  role        MessageRole
  text        String?
  // voice, image, file, etc.
  contentJson Json?

  // External references (WhatsApp message id, etc.)
  externalMessageId String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([organizationId])
}

/// --------------------
/// Files & Knowledge (catalogs, docs, embeddings-ready)
/// --------------------
model FileObject {
  id             String      @id @default(cuid())
  organizationId String
  projectId      String?
  purpose        FilePurpose @default(OTHER)

  name      String
  mimeType  String?
  sizeBytes Int?

  // storage pointers: S3/R2/Drive etc
  storageProvider String? // "r2", "s3", "gdrive"
  storageKey      String?
  url             String?

  metadataJson Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  knowledgeItems KnowledgeItem[]
  documents      Document[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId, purpose])
  @@index([projectId])
}

model KnowledgeItem {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String?
  title          String
  content        String?
