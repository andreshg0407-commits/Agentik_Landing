  /// ReasoningStatus: SUCCESS | PARTIAL | INSUFFICIENT_EVIDENCE | ERROR
  status              String

  /// ReasoningConfidence: LOW | MEDIUM | HIGH | VERY_HIGH
  confidenceLevel     String

