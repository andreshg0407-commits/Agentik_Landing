  confidenceScore     Float  @default(0)

  signalCount         Int    @default(0)
  evidenceCount       Int    @default(0)
  hypothesisCount     Int    @default(0)
  riskCount           Int    @default(0)
  opportunityCount    Int    @default(0)
  recommendationCount Int    @default(0)

