// Agentik schema
// Prisma 7 config-first setup
// ⚠️ DATABASE URL lives in prisma.config.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// --------------------
/// Enums
/// --------------------
enum OrgType {
  SAAS_CUSTOMER
  ENTERPRISE
  INTERNAL
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  PAUSED
  ARCHIVED
}

enum Role {
  SUPER_ADMIN    // Agentik superuser — overrides everything
  AGENTIK_ADMIN  // Agentik internal platform admin — Consola Interna only, no client data
  ORG_ADMIN      // Client org admin — fully client-facing, no internal console
  MANAGER
  OPERATOR
  VIEWER
  BILLING
}

enum MembershipStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum AgentType {
  MARKETING
  SALES
  WEB_MANAGER
  ACCOUNTING
  OPS
  CUSTOM
}

enum AgentStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ChannelType {
  WHATSAPP
  TIKTOK
  INSTAGRAM
  FACEBOOK
  WEB
  EMAIL
  API
}

enum IntegrationProvider {
  META
  TIKTOK
  GOOGLE
  SHOPIFY
  STRIPE
  ZELLE
  MERCURY
  DIAN
  PYA
  CUSTOM
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
}

enum WorkflowProvider {
  N8N
  CUSTOM
}

enum WorkflowStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum RunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum ConversationStatus {
  OPEN
  PENDING_HANDOFF
  HANDED_OFF
  CLOSED
}

enum MessageRole {
  USER
  AGENT
  TOOL
  SYSTEM
}

enum FilePurpose {
  CATALOG
  BRAND_ASSET
  DOCUMENT
  PROMPT_ATTACHMENT
  OTHER
}

enum PlanInterval {
  MONTH
  YEAR
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum SyncJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum RuleStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum RuleExecutionStatus {
  MATCHED
  SKIPPED
  FAILED
}

enum EventStatus {
  PENDING
  PROCESSED
  FAILED
}

enum UsageKind {
  LLM_TOKENS
  LLM_CALL
  IMAGE_GEN
  VIDEO_GEN
  STORAGE
  WORKFLOW_RUN
  MESSAGE
}

enum ActionTaskStatus {
  PENDING
  SCHEDULED
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

enum ActionTaskType {
  CREAR_TAREA_COMERCIAL
  ASIGNAR_SEGUIMIENTO_VENDEDOR
  MARCAR_CLIENTE_RECUPERACION
  GENERAR_INFORME
  PROGRAMAR_INFORME
  ABRIR_ALERTA_OPERATIVA
  CREAR_ACCION_COBRANZA
  ESCALAR_A_GERENCIA
}

enum ActionTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NotificationType {
  ACTION_ASSIGNED
  ACTION_REASSIGNED
  ACTION_DUE_TODAY
  ACTION_OVERDUE
  ACTION_COMPLETED
  SCHEDULED_REPORT_READY
  SCHEDULED_REPORT_FAILED
  SYSTEM
}

enum ScheduleFrequency {
  ONCE
  WEEKLY
  MONTHLY
}

/// --------------------
/// Tenant / Identity
/// --------------------
model Organization {
  id     String    @id @default(cuid())
  name   String
  slug   String    @unique
  type   OrgType   @default(ENTERPRISE)
  status OrgStatus @default(ACTIVE)

  // Branding / preferences per org
  settingsJson Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  members         Membership[]
  workspaces      Workspace[]
  projects        Project[]
  agents          Agent[]
  channels        Channel[]
  integrations    Integration[]
  workflows       Workflow[]
  files           FileObject[]
  knowledge       KnowledgeItem[]
  runs            Run[]
  logs            AgentLog[]
  audits          AuditLog[]
  subscriptions   Subscription[]
  conversations   Conversation[]
  messages        Message[]
  usageEvents     UsageEvent[]
  events          Event[]
  rules           Rule[]
  alerts          Alert[]
  metricSnapshots  MetricSnapshot[]
  syncJobs         SyncJob[]
  documents        Document[]
  productSnapshots ProductSnapshot[]
  orderSnapshots   OrderSnapshot[]
  salesImportBatches  SalesImportBatch[]
  saleRecords         SaleRecord[]
  businessAlerts      BusinessAlert[]
  connectors          Connector[]
  customerProfiles    CustomerProfile[]
  customerReceivables CustomerReceivable[]
  crmOpportunities    CRMOpportunity[]
  crmActivities       CRMActivity[]
  crmQuotes           CRMQuote[]
  pipelineStages      PipelineStage[]
  sagWriteOperations  SagWriteOperation[]
  actionTasks         ActionTask[]
  notifications       Notification[]
  scheduledReports    ScheduledReport[]
  budgets             Budget[]
  tenantModules       TenantModule[]
  whatsAppConfig          WhatsAppConfig?
  whatsAppConversations   WhatsAppConversation[]
  whatsAppContactMemories WhatsAppContactMemory[]
  studioSessions          StudioSession[]

  @@index([status])
}

model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?
  phone String?

  // Auth.js v5 required fields
  emailVerified DateTime?
  image         String?

  // Auth strategy: password hash or oauth provider; keep flexible
  authJson Json?

  memberships          Membership[]
  auditLogs            AuditLog[]           @relation("UserAuditLogs")
  assignedAlerts       Alert[]              @relation("AssignedAlerts")
  // Auth.js relations
  accounts             Account[]
  sessions             Session[]
  passwordCredential   PasswordCredential?
  // Workspace-level access (multi-tenant)
  workspaceMemberships WorkspaceMembership[]
  uploadedDocuments    Document[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Membership {
  id             String @id @default(cuid())
  organizationId String
  userId         String
  role           Role   @default(VIEWER)

  status          MembershipStatus @default(INVITED)
  invitedAt       DateTime?
  acceptedAt      DateTime?
  disabledAt      DateTime?
  permissionsJson Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId, status])
}

/// --------------------
/// Projects (modules / initiatives)
/// --------------------
model Project {
  id             String        @id @default(cuid())
  organizationId String
  // Optional: scope this technical initiative to a brand/client workspace
  workspaceId    String?
  name           String
  key            String // REQUIRED stable key like "dojeans-control-center"
  status         ProjectStatus @default(PLANNED)
  description    String?
  settingsJson   Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  agents          Agent[]
  channels        Channel[]
  integrations    Integration[]
  workflows       Workflow[]
  knowledge       KnowledgeItem[]
  files           FileObject[]
  runs            Run[]
  audits          AuditLog[]
  projectModules  ProjectModule[]
  conversations   Conversation[]
  usageEvents     UsageEvent[]
  events          Event[]
  rules           Rule[]
  alerts          Alert[]
  metricSnapshots MetricSnapshot[]
  syncJobs        SyncJob[]
  logs            AgentLog[] // ✅ relación real para AgentLog (mejora producción)
  documents       Document[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // ✅ Esto es CLAVE: de aquí sale el unique input `organizationId_key` en Prisma (seed correcto)
  @@unique([organizationId, key])
  @@index([organizationId, status])
  @@index([key]) // (opcional) útil para búsquedas rápidas por key
  @@index([workspaceId])
}

/// Optional: which “modules” are enabled in a project (phased rollout)
model ProjectModule {
  id         String  @id @default(cuid())
  projectId  String
  // Examples: “CONTROL_CENTER”, “MILA_WHATSAPP”, “LUCA_MARKETING”, “DIAN_AUTOMATION”
  code       String
  enabled    Boolean @default(false)
  configJson Json?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, code])
  @@index([projectId, enabled])
}

/// Per-org feature flags for UI modules.
/// Open by default: if no row exists for a (org, moduleKey) pair the module is considered ENABLED.
/// Only explicit enabled=false rows hide modules.
/// Keys match the ModuleKey enum in lib/tenant/modules.ts.
model TenantModule {
  id             String  @id @default(cuid())
  organizationId String
  /// Canonical module key — see ModuleKey in lib/tenant/modules.ts
  moduleKey      String
  enabled        Boolean @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, moduleKey])
  @@index([organizationId, enabled])
}

/// --------------------
/// Agents (Luca, Mila, etc.)
/// --------------------
model Agent {
  id             String      @id @default(cuid())
  organizationId String
  projectId      String?
  name           String
  type           AgentType   @default(CUSTOM)
  status         AgentStatus @default(DRAFT)

  // Runtime selection
  modelProvider   String? // "anthropic", "openai", "google", etc.
  modelName       String? // "claude-...", "gpt-...", "gemini-..."
  temperature     Float?
  topP            Float?
  maxOutputTokens Int?

  // FIX: two relations Agent<->AgentVersion must be named + opposite fields exist
  versions AgentVersion[] @relation("AgentVersions")

  activeVersionId String?
  activeVersion   AgentVersion? @relation("ActiveAgentVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)

  // Freeform config (for quick start); recommended to use versions below
  configJson Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  channels       Channel[]
  conversations  Conversation[]
  logs           AgentLog[]
  runs           Run[]
  knowledgeLinks KnowledgeLink[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, name])
  @@index([organizationId, status])
  @@index([projectId])
}

model AgentVersion {
  id      String  @id @default(cuid())
  agentId String
  version Int
  label   String?

  // Prompting + policy + tools instructions
  systemPrompt String?
  policyJson   Json?
  toolsJson    Json?

  // Persona / style / forbidden words / sales rules / etc.
  behaviorJson Json?

  // Domain knowledge references: tags, categories, etc.
  metadataJson Json?

  agent Agent @relation("AgentVersions", fields: [agentId], references: [id], onDelete: Cascade)

  // Opposite side for activeVersion
  activeFor Agent[] @relation("ActiveAgentVersion")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agentId, version])
  @@index([agentId])
}

/// --------------------
/// Channels & Integrations
/// --------------------
model Channel {
  id             String  @id @default(cuid())
  organizationId String
  projectId      String?
  agentId        String?
  integrationId  String?

  type   ChannelType
  name   String? // e.g. "Mila WPP DoJeans"
  status String? // keep flexible (Meta statuses vary)

  // Phone/page/account identifiers depending on channel
  externalAccountId String?
  externalPhoneId   String?
  externalPageId    String?

  // Store secrets/credentials encrypted at app layer (prefer Integration.secretsJson in prod)
  credentialsJson Json?
  settingsJson    Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  agent        Agent?       @relation(fields: [agentId], references: [id], onDelete: SetNull)
  integration  Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  conversations Conversation[]
  runs          Run[]
  agentLogs     AgentLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId, type])
  @@index([projectId])
  @@index([agentId])
  @@index([integrationId])
}

model Integration {
  id             String              @id @default(cuid())
  organizationId String
  projectId      String?
  provider       IntegrationProvider
  name           String?

  status       IntegrationStatus @default(DISCONNECTED)
  lastSyncedAt DateTime?
  lastError    String?

  // OAuth tokens, API keys, endpoints, etc. (encrypted by app layer)
  secretsJson Json?
  // Non-sensitive settings/ids
  configJson  Json?
  metaJson    Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  channels Channel[]
  syncJobs SyncJob[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId, provider])
  @@index([projectId])
  @@index([organizationId, status])
}

/// --------------------
/// Workflows (n8n, custom) + Runs
/// --------------------
model Workflow {
  id             String           @id @default(cuid())
  organizationId String
  projectId      String?
  provider       WorkflowProvider @default(N8N)
  status         WorkflowStatus   @default(ACTIVE)

  name        String
  // For n8n: workflow ID, webhook URLs, etc.
  externalId  String?
  endpointUrl String?
  configJson  Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  runs Run[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId, status])
  @@index([projectId])
}

model Run {
  id             String  @id @default(cuid())
  organizationId String
  projectId      String?
  agentId        String?
  channelId      String?
  workflowId     String?
  conversationId String?

  // Job OS fields
  type        String   @default("generic") // e.g. "marketing.image_to_video"
  traceId     String?
  attempt     Int      @default(0)
  maxAttempts Int      @default(3)
  queuedAt    DateTime @default(now())

  status RunStatus @default(QUEUED)

  // Useful for idempotency / retries
  // ✅ Mantén NULL cuando no exista (no uses "" en app).
  idempotencyKey String?

  inputJson  Json?
  outputJson Json?
  errorJson  Json?

  startedAt DateTime?
  endedAt   DateTime?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  agent        Agent?        @relation(fields: [agentId], references: [id], onDelete: SetNull)
  channel      Channel?      @relation(fields: [channelId], references: [id], onDelete: SetNull)
  workflow     Workflow?     @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  logs   AgentLog[]
  events Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([projectId])
  @@index([agentId])
  @@index([workflowId])
  @@index([conversationId])
}

/// --------------------
/// Conversations (Mila) + Messages
/// --------------------
model Conversation {
  id             String             @id @default(cuid())
  organizationId String
  projectId      String?
  agentId        String?
  channelId      String?
  status         ConversationStatus @default(OPEN)

  // For WhatsApp: customer phone; for web: session id; etc.
  externalThreadId String?
  customerName     String?
  customerHandle   String? // phone/email/username
  metadataJson     Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  agent        Agent?       @relation(fields: [agentId], references: [id], onDelete: SetNull)
  channel      Channel?     @relation(fields: [channelId], references: [id], onDelete: SetNull)

  messages Message[]
  runs     Run[]
  logs     AgentLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime?

  @@index([organizationId, status])
  @@index([agentId])
  @@index([channelId])
  @@index([customerHandle])
}

model Message {
  id             String @id @default(cuid())
  organizationId String
  conversationId String

  role        MessageRole
  text        String?
  // voice, image, file, etc.
  contentJson Json?

  // External references (WhatsApp message id, etc.)
  externalMessageId String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([organizationId])
}

/// --------------------
/// Files & Knowledge (catalogs, docs, embeddings-ready)
/// --------------------
model FileObject {
  id             String      @id @default(cuid())
  organizationId String
  projectId      String?
  purpose        FilePurpose @default(OTHER)

  name      String
  mimeType  String?
  sizeBytes Int?

  // storage pointers: S3/R2/Drive etc
  storageProvider String? // "r2", "s3", "gdrive"
  storageKey      String?
  url             String?

  metadataJson Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  knowledgeItems KnowledgeItem[]
  documents      Document[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId, purpose])
  @@index([projectId])
}

model KnowledgeItem {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String?
  title          String
  content        String?
  contentJson    Json?
  tags           String[] @default([])

  // future: embedding vector stored externally or in pgvector later
  embeddingRef String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  files      FileObject[]
  agentLinks KnowledgeLink[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId])
  @@index([projectId])
}

model KnowledgeLink {
  id          String @id @default(cuid())
  agentId     String
  knowledgeId String

  agent     Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  knowledge KnowledgeItem @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([agentId, knowledgeId])
}

/// --------------------
/// Logging / Audit / Usage (cost control)
/// --------------------
model AgentLog {
  id             String  @id @default(cuid())
  organizationId String
  projectId      String?
  agentId        String?
  channelId      String?
  conversationId String?
  runId          String?

  inputJson  Json?
  outputJson Json?
  errorJson  Json?

  // Cost control (Decimal instead of Float)
  provider  String?
  model     String?
  tokensIn  Int?
  tokensOut Int?
  costUsd   Decimal? @db.Decimal(14, 6)

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  agent        Agent?        @relation(fields: [agentId], references: [id], onDelete: SetNull)
  channel      Channel?      @relation(fields: [channelId], references: [id], onDelete: SetNull)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  run          Run?          @relation(fields: [runId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([agentId, createdAt])
  @@index([projectId, createdAt])
  @@index([runId])
}

model AuditLog {
  id             String  @id @default(cuid())
  organizationId String
  projectId      String?
  actorUserId    String?

  traceId String? // add traceability

  action      String
  targetType  String?
  targetId    String?
  detailsJson Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  actorUser    User?        @relation("UserAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([projectId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([traceId])
}

model UsageEvent {
  id             String    @id @default(cuid())
  organizationId String
  projectId      String?
  kind           UsageKind
  quantity       Int       @default(1)

  unitCostUsd  Decimal? @db.Decimal(12, 6)
  totalCostUsd Decimal? @db.Decimal(14, 6)

  metadataJson Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([projectId, createdAt])
  @@index([kind, createdAt])
}

/// --------------------
/// Billing (SaaS-ready)
/// --------------------
model Plan {
  id          String       @id @default(cuid())
  code        String       @unique // "basic", "pro", "enterprise"
  name        String
  description String?
  interval    PlanInterval @default(MONTH)

  // ✅ Más estable con default string en Decimal
  priceUsd Decimal @default("0") @db.Decimal(10, 2)

  limitsJson Json? // usage limits, feature flags

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id             String             @id @default(cuid())
  organizationId String
  planId         String
  status         SubscriptionStatus @default(TRIALING)

  // Provider details (Stripe/manual/etc.)
  provider               String?
  providerCustomerId     String?
  providerSubscriptionId String?
  cancelAtPeriodEnd      Boolean   @default(false)
  trialEndsAt            DateTime?

  // Stripe ids, etc
  billingJson Json?

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([planId])
}

/// --------------------
/// Sync / Import Jobs
/// --------------------
model SyncJob {
  id             String        @id @default(cuid())
  organizationId String
  projectId      String?
  integrationId  String?
  type           String // "bank.import", "sag.export.sync"
  traceId        String?
  status         SyncJobStatus @default(QUEUED)
  inputJson      Json?
  outputJson     Json?
  errorJson      Json?
  startedAt      DateTime?
  endedAt        DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  integration  Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status, type])
  @@index([integrationId])
  @@index([traceId])
}

/// --------------------
/// Alerts
/// --------------------
model Alert {
  id             String        @id @default(cuid())
  organizationId String
  projectId      String?
  type           String // "inventory.low", "portfolio.overdue"
  title          String
  message        String
  severity       AlertSeverity @default(INFO)
  status         AlertStatus   @default(OPEN)
  sourceType     String?
  sourceId       String?
  assignedUserId String?
  metadataJson   Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignedUser User?        @relation("AssignedAlerts", fields: [assignedUserId], references: [id], onDelete: SetNull)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  @@index([organizationId, status, severity])
  @@index([projectId, status])
  @@index([type, createdAt])
  @@index([assignedUserId])
}

/// --------------------
/// Rules & Executions (event-driven automation)
/// --------------------
model Rule {
  id             String     @id @default(cuid())
  organizationId String
  projectId      String?
  moduleCode     String?
  name           String
  description    String?
  eventType      String // "inventory.updated"
  conditionJson  Json // condición evaluable
  actionJson     Json // acción o acciones
  priority       Int        @default(100)
  status         RuleStatus @default(ACTIVE)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  executions RuleExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, eventType, status])
  @@index([projectId, status])
}

model RuleExecution {
  id         String              @id @default(cuid())
  ruleId     String
  eventId    String
  status     RuleExecutionStatus
  resultJson Json?
  errorJson  Json?

  rule  Rule  @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([ruleId, createdAt])
  @@index([eventId])
}

/// --------------------
/// Metric Snapshots (time-series KPIs)
/// --------------------
model MetricSnapshot {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String?
  code           String // "sales.daily", "inventory.critical.count"
  label          String?
  valueNumber    Decimal? @db.Decimal(18, 4)
  valueJson      Json?
  snapshotAt     DateTime
  metadataJson   Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([organizationId, code, snapshotAt])
  @@index([projectId, snapshotAt])
}

/// --------------------
/// Events (domain event bus)
/// --------------------
model Event {
  id             String      @id @default(cuid())
  organizationId String
  projectId      String?
  type           String // "inventory.updated", "invoice.received"
  sourceType     String? // "integration", "api", "workflow", "user"
  sourceId       String?
  traceId        String?
  runId          String?
  payloadJson    Json
  status         EventStatus @default(PENDING)
  processedAt    DateTime?
  errorJson      Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  run          Run?         @relation(fields: [runId], references: [id], onDelete: SetNull)

  ruleExecutions RuleExecution[]

  createdAt DateTime @default(now())

  @@index([organizationId, type, createdAt])
  @@index([projectId, createdAt])
  @@index([status, createdAt])
  @@index([traceId])
  @@index([runId])
}

/// --------------------
/// Enums nuevos
/// --------------------

/// Distingue si un Workspace es una marca (Castillitos/Latin Kids/Pets)
/// o un cliente externo (caso ARKETOPS) o una unidad interna.
enum WorkspaceType {
  BRAND      // línea de negocio o marca propia
  CLIENT     // cliente externo con su propio dashboard
  DEPARTMENT // área interna de la org
  INTERNAL   // uso interno de la plataforma
}

/// Categoría estructural del documento para enrutamiento y validación.
enum DocumentType {
  XML                // CFDI, facturas electrónicas, etc.
  PDF
  BANK_STATEMENT     // extracto bancario
  ACCOUNTING_SUPPORT // soporte contable / voucher
  TAX_DOCUMENT       // declaración, certificado tributario
  COMMERCIAL_DOCUMENT // orden de compra, contrato, remisión
  OTHER
}

/// Estado del pipeline de procesamiento del documento.
enum DocumentStatus {
  PENDING    // subido, sin procesar
  PROCESSING // en cola o siendo parseado
  PROCESSED  // extracción completada
  REVIEWED   // revisado por usuario
  REJECTED   // rechazado / inválido
  ERROR      // fallo en procesamiento
}

/// --------------------
/// Auth.js v5 — modelos requeridos
/// --------------------

/// Cuentas OAuth vinculadas a un User (Google, GitHub, Meta, etc.)
/// Campos y nombres son exactamente los que espera Auth.js.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String  // "oauth" | "oidc" | "email"
  provider          String  // "google", "github", "credentials"
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

/// Sesiones activas (strategy: "database" de Auth.js).
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Tokens para magic-link / email verification (Auth.js).
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Credencial de contraseña separada del User para no mezclar
/// campos sensibles con el perfil público. Alternativa limpia a authJson.
model PasswordCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  passwordHash String   // bcrypt / argon2 hash — NUNCA texto plano
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// --------------------
/// Multi-tenant: Workspace (marca / cliente / unidad operativa)
/// --------------------

/// Workspace es la capa entre Organization y Project.
/// Para Castillitos: un Workspace por marca (Castillitos, Latin Kids, Pets).
/// Para ARKETOPS: un Workspace por cliente externo.
/// Los Projects (iniciativas técnicas) quedan opcionalmente anclados a un Workspace.
model Workspace {
  id             String        @id @default(cuid())
  organizationId String
  type           WorkspaceType @default(BRAND)
  name           String
  slug           String

  description  String?
  logoUrl      String?
  settingsJson Json?

  // Si es un cliente externo: datos de contacto del cliente
  contactName  String?
  contactEmail String?
  contactPhone String?

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships  WorkspaceMembership[]
  projects     Project[]
  documents    Document[]
  productSnapshots ProductSnapshot[]
  orderSnapshots   OrderSnapshot[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // slug único dentro de la org (no global, cada empresa puede tener su propio slug)
  @@unique([organizationId, slug])
  @@index([organizationId, type])
}

/// Acceso de un User a un Workspace específico.
/// Usuarios internos (ARKETOPS staff) pueden tener múltiples WorkspaceMemberships.
/// Clientes externos solo deben tener una WorkspaceMembership en su propio Workspace.
model WorkspaceMembership {
  id          String           @id @default(cuid())
  workspaceId String
  userId      String
  role        Role             @default(VIEWER) // reutiliza el enum existente
  status      MembershipStatus @default(INVITED)

  invitedAt  DateTime?
  acceptedAt DateTime?
  // Permisos adicionales granulares si hacen falta
  permissionsJson Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, status])
}

/// --------------------
/// Document (modelo genérico de documentos estructurados)
/// --------------------

/// Representa cualquier documento formal: XML fiscal, PDF, extracto bancario,
/// soporte contable, documento comercial, etc.
/// Vinculado a FileObject para el binario real; aquí vive la metadata extraída.
model Document {
  id             String         @id @default(cuid())
  organizationId String
  workspaceId    String?
  projectId      String?
  fileObjectId   String?        // archivo fuente en storage
  createdById    String?

  type           DocumentType
  category       String?        // sub-categoría libre: "cfdi_ingreso", "estado_cuenta_mercury"
  title          String
  description    String?
  status         DocumentStatus @default(PENDING)

  // Resultado de parsing / extracción estructurada
  extractedJson  Json?

  // Campos fiscales / comerciales comunes (desnormalizados para queries rápidas)
  issuerName     String?        // emisor / proveedor
  issuerId       String?        // NIT, RUC, RFC, CUIT del emisor
  receiverName   String?        // receptor / empresa
  receiverId     String?        // ID fiscal del receptor
  documentDate   DateTime?
  amount         Decimal?       @db.Decimal(18, 4)
  currency       String?        @default("USD")

  metadataJson   Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  file         FileObject?  @relation(fields: [fileObjectId], references: [id], onDelete: SetNull)
  createdBy    User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId, type, status])
  @@index([workspaceId, type])
  @@index([projectId])
  @@index([fileObjectId])
  @@index([issuerId])
  @@index([documentDate])
  @@index([createdById])
}

/// --------------------
/// External Data Snapshots — reusable canonical models for connector ingestion
/// sourceSystem = "pya" | "shopify" | "stripe" | etc.
/// @@unique([organizationId, sourceSystem, sourceId]) enables idempotent upserts.
/// --------------------

model ProductSnapshot {
  id             String  @id @default(cuid())
  organizationId String
  workspaceId    String?
  sourceSystem   String  // connector identifier: "pya", "shopify", etc.
  sourceId       String  // external product ID

  // Normalized fields (connector-agnostic)
  name        String
  sku         String?
  description String?
  category    String?
  price       Decimal? @db.Decimal(18, 4)
  currency    String?  @default("USD")
  status      String?  // "active" | "inactive" | source-specific value
  imageUrl    String?

  // Full raw payload for auditability and future enrichment
  payloadJson Json?
  syncedAt    DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, sourceSystem, sourceId])
  @@index([organizationId, sourceSystem])
  @@index([workspaceId])
  @@index([status])
}

model OrderSnapshot {
  id             String  @id @default(cuid())
  organizationId String
  workspaceId    String?
  sourceSystem   String  // connector identifier: "pya", "shopify", etc.
  sourceId       String  // external order ID

  // Normalized fields (connector-agnostic)
  status       String?  // "pending" | "confirmed" | "delivered" | source-specific
  totalAmount  Decimal? @db.Decimal(18, 4)
  currency     String?  @default("USD")
  customerId   String?  // external customer ID if available
  customerName String?
  orderedAt    DateTime?

  // Full raw payload for auditability and future enrichment
  payloadJson Json?
  syncedAt    DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, sourceSystem, sourceId])
  @@index([organizationId, sourceSystem])
  @@index([workspaceId])
  @@index([orderedAt])
  @@index([status])
}

/// --------------------
/// Sales Intelligence
/// --------------------

enum SaleGrain {
  TRANSACTION  // each row is one sale event
  AGGREGATED   // each row is a SAG pre-grouped summary
}

enum SaleChannel {
  TIENDA
  ONLINE
  TELEFONO
  DISTRIBUIDOR
  MAYORISTA
  OTRO
}

/// Source-family classification for SAG comprobante codes.
///
/// Derived at import time from cod_comprobante via the tenant's
/// documentFamilyMap (stored in Connector.config). Defaults to OTHER
/// until the map is configured and confirmed against the SAG manual.
///
/// See lib/sales/sag-document-type.ts for the classification logic
/// and https://pya.com.co/wp-content/uploads/2026/02/Manual-SAG.html
/// for the authoritative PYA code reference.
enum SagDocumentFamily {
  /// Factura de venta (fiscal invoice — creates receivable in cartera)
  OFFICIAL_INVOICE
  /// Remisión / Nota de entrega (dispatch only — no receivable created)
  DISPATCH_REMISION
  /// Nota crédito (reduces receivable / reversal)
  CREDIT_NOTE
  /// Nota débito (increases receivable / adjustment)
  DEBIT_NOTE
  /// Unclassified — cod_comprobante absent or not in documentFamilyMap
  OTHER
}

/// High-level commercial source: Fuente 1 (official billing) vs Fuente 2 (remision/dispatch).
/// Derived from sagDocumentFamily at import time; can be overridden via import wizard.
///
///   OFICIAL  — Fuente 1: factura fiscal; recognized revenue; creates receivable in cartera.
///   REMISION — Fuente 2: remisión / nota de entrega; operational demand; pending conversion.
enum SagSourceType {
  OFICIAL    // Fuente 1 — official invoice, recognized revenue
  REMISION   // Fuente 2 — remisión / dispatch, pending conversion to invoice
}

/// Lifecycle stage of the commercial document at import time.
/// Flows: PENDIENTE → DESPACHADO → REMITIDO → FACTURADO
enum SourceDocumentStage {
  FACTURADO   // Invoice issued — official fiscal document, revenue recognized
  REMITIDO    // Remisión issued — goods dispatched, invoice pending
  DESPACHADO  // Goods dispatched but not yet documented as remisión or invoice
  PENDIENTE   // Document pending — awaiting any formal stage
}

/// Defines what period a SalesImportBatch covers and therefore what it replaces.
enum SaleScopeType {
  MONTH   // scopeKey = "YYYYMM" e.g. "202403"
  RANGE   // scopeKey = "YYYY-MM-DD:YYYY-MM-DD"
  YEAR    // scopeKey = "YYYY"
  ADHOC   // scopeKey = cuid — no replacement semantics
}

/// One import batch = one CSV/Excel file from SAG.
/// A batch with the same (organizationId, scopeType, scopeKey) replaces any
/// previous batch with the same scope — old records are deleted before insert.
model SalesImportBatch {
  id             String        @id @default(cuid())
  organizationId String

  // Source
  source         String        @default("csv") // "csv" | "manual"
  grain          SaleGrain     @default(TRANSACTION)
  fileName       String?

  // Scope — what this batch covers and replaces
  scopeType      SaleScopeType @default(MONTH)
  scopeKey       String        // e.g. "202403", "2024", "2024-03-01:2024-03-31"

  // Replacement tracking: when a batch is superseded, we set replacedByBatchId on it
  replacedByBatchId String?

  // Status
  status         String        @default("PENDING") // PENDING|PROCESSING|DONE|FAILED|SUPERSEDED
  rowCount       Int           @default(0)
  importedCount  Int           @default(0)
  skippedCount   Int           @default(0)
  errorJson      Json?

  importedAt     DateTime      @default(now())
  importedBy     String?

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  records        SaleRecord[]

  @@index([organizationId, scopeType, scopeKey])
  @@index([organizationId, status])
  @@index([organizationId, importedAt])
}

/// One normalized sale row from a SAG export.
/// naturalKey is a short hash of the row's stable fields (excluding organizationId);
/// uniqueness is enforced at org scope via @@unique([organizationId, naturalKey]).
model SaleRecord {
  id             String      @id @default(cuid())
  organizationId String
  importBatchId  String
  grain          SaleGrain

  // ── Temporal ────────────────────────────────────────────────────────────────
  saleDate       DateTime    // UTC midnight of the sale date
  periodoAoMes   String?     // original SAG field, e.g. "202403"

  // ── Seller ──────────────────────────────────────────────────────────────────
  sellerCode     String?     // SAG code if available, e.g. "V001"
  sellerSlug     String      // stable slug: toSlug(sellerName), used as join key
  sellerName     String

  // ── Store ───────────────────────────────────────────────────────────────────
  storeCode      String?     // SAG store code if available
  storeSlug      String
  storeName      String

  // ── Product / Line ───────────────────────────────────────────────────────────
  productLine    String
  brand          String?
  productCode    String?
  productName    String?

  // ── Geography ────────────────────────────────────────────────────────────────
  zone           String?

  // ── Transaction ──────────────────────────────────────────────────────────────
  channel        SaleChannel
  comprobanteCode String?     // raw SAG code, e.g. "FV", "NV" (alias: cod_comprobante)
  comprobante    String?      // full reference, e.g. "FV-001234"

  // ── Document source classification ────────────────────────────────────────────
  // Derived from comprobanteCode via Connector.config.documentFamilyMap at import.
  // Defaults to OTHER until the tenant map is configured and confirmed.
  // See: lib/sales/sag-document-type.ts
  sagDocumentFamily SagDocumentFamily @default(OTHER)

  // ── Source awareness (Fuente 1 / Fuente 2) ────────────────────────────────────
  // sagSourceType:        derived from sagDocumentFamily + heuristics at import time.
  //                       OFICIAL = Fuente 1 (recognized revenue).
  //                       REMISION = Fuente 2 (operational demand, pending conversion).
  // sourceDocumentStage:  lifecycle stage at import (FACTURADO | REMITIDO | DESPACHADO | PENDIENTE).
  //
  // Finance rules:
  //   - Only OFICIAL contributes to recognized revenue, budget actuals, and DIAN reconciliation.
  //   - REMISION contributes to operational demand, near-term forecast, and conversion tracking.
  //   - REMISION not converted to OFICIAL after X days surfaces as a pending conversion risk.
  sagSourceType        SagSourceType        @default(OFICIAL)
  sourceDocumentStage  SourceDocumentStage  @default(FACTURADO)
  // Audit: which signal determined sagSourceType at import time.
  // Values: "family" | "explicit_column" | "code_pattern" | "ref_pattern" | "filename" | "default" | "legacy"
  // "legacy" = imported before source-tracking sprint (FUENTE_1 assumed conservatively).
  sourceInferredFrom   String               @default("legacy")

  // Reference to an origin or related document.
  // E.g.: a remisión's number may reference the original order or a later invoice.
  // Populated from export fields when available (Castillitos field: TBD — confirm
  // against SAG manual https://pya.com.co/wp-content/uploads/2026/02/Manual-SAG.html).
  originDocumentRef String?

  // ── Customer ─────────────────────────────────────────────────────────────────
  customerNit    String?
  customerName   String?

  // ── Measures ─────────────────────────────────────────────────────────────────
  amount         Decimal     @db.Decimal(18, 2)
  currency       String      @default("COP")
  units          Int?
  // txCount: for TRANSACTION grain always 1.
  // For AGGREGATED: SAG-provided count when available, NULL when SAG did not export it.
  // NULL signals "unknown count" — do not compute avgTicket from this row.
  txCount        Int?

  // ── Deduplication ────────────────────────────────────────────────────────────
  // Short SHA-256 hash of row's natural key fields (grain-specific, excludes orgId).
  // Combined with organizationId for org-scoped uniqueness.
  naturalKey     String

  // ── Audit ────────────────────────────────────────────────────────────────────
  rawJson        Json        // original SAG row

  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  importBatch    SalesImportBatch   @relation(fields: [importBatchId], references: [id])

  @@unique([organizationId, naturalKey])
  @@index([organizationId, saleDate])
  @@index([organizationId, periodoAoMes])
  @@index([organizationId, sellerSlug, saleDate])
  @@index([organizationId, storeSlug, saleDate])
  @@index([organizationId, productLine, saleDate])
  @@index([organizationId, channel, saleDate])
  @@index([organizationId, comprobanteCode])
  @@index([organizationId, sagDocumentFamily, saleDate])
  @@index([organizationId, customerNit])
  @@index([importBatchId])
  // Source-awareness indexes — enable fast Fuente 1 / Fuente 2 filtering
  @@index([organizationId, sagSourceType, saleDate])
  @@index([organizationId, sagSourceType, sellerSlug, saleDate])
  @@index([organizationId, sagSourceType, storeSlug, saleDate])
  @@index([organizationId, sagSourceType, sourceDocumentStage, saleDate])
  // Audit index — identify legacy-assumed rows needing review
  @@index([organizationId, sourceInferredFrom])
}

/// Persisted result of the source dedup engine (F2 ↔ F1 matching).
///
/// One row per REMISION SaleRecord (f2RecordId is unique).
/// isOrphan = true  → no matching F1 found in MAX_DATE_GAP_DAYS window.
/// isOrphan = false → matched to f1RecordId with given signal and confidence.
///
/// Regenerated by persistDedupResults() after every import batch.
/// All modules that need conversion / orphan data read from here — not re-computing.
///
/// Dedup key: (organizationId, f2RecordId) — upsert on re-import.
model SourceMatchRecord {
  id             String   @id @default(cuid())
  organizationId String

  /// The REMISION SaleRecord this row describes.
  f2RecordId     String
  /// The matching OFICIAL SaleRecord. NULL when isOrphan = true.
  f1RecordId     String?

  /// Period of the F2 record (YYYYMM).
  periodoAoMes   String

  // ── Match result ──────────────────────────────────────────────────────────
  /// True when no plausible F1 match was found within MAX_DATE_GAP_DAYS.
  isOrphan       Boolean  @default(true)
  /// Signal that produced the match. NULL when isOrphan.
  /// "origin_doc_ref" | "comprobante_number" | "customer_amount_date" | "seller_store_amount"
  matchSignal    String?
  /// Matching confidence 0–100. NULL when isOrphan.
  confidence     Int?
  /// Days between F2 saleDate and F1 saleDate. NULL when isOrphan.
  conversionDays Int?
  /// (f1.amount - f2.amount) / f2.amount × 100. NULL when isOrphan.
  amountDeltaPct Float?

  // ── Orphan risk (only meaningful when isOrphan = true) ────────────────────
  /// "NONE" | "LOW" | "MEDIUM" | "HIGH" | "CRITICAL" — based on daysPending at generation time.
  orphanRisk     String?
  /// Days since F2 saleDate at the moment this record was last generated.
  orphanDays     Int?

  // ── Denormalized for fast querying without joining SaleRecord ─────────────
  customerNit    String?
  sellerSlug     String
  storeSlug      String
  f2Amount       Float
  f2Date         DateTime

  generatedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, f2RecordId])
  @@index([organizationId, periodoAoMes])
  @@index([organizationId, isOrphan, orphanRisk])
  @@index([organizationId, sellerSlug, periodoAoMes])
  @@index([organizationId, customerNit, periodoAoMes])
  @@index([organizationId, isOrphan, periodoAoMes])
}

/// Business alert generated by the Alert Engine from sales/finance/operational data.
/// Deduplicated by (organizationId, type, entityKey, period) — re-running the same
/// period updates the existing alert rather than creating a duplicate.
model BusinessAlert {
  id             String        @id @default(cuid())
  organizationId String

  // Classification
  module         String        // "sales" | "finance" | "production"
  type           String        // "sales_drop" | "seller_dependency"
  severity       AlertSeverity @default(WARNING)
  status         AlertStatus   @default(OPEN)

  // Content
  title          String
  message        String

  // Entity the alert is about
  entityType     String        // "seller" | "store" | "product_line"
  entityKey      String        // slug or stable key
  entityLabel    String        // human-readable name

  // Temporal scope
  period         String        // "YYYYMM" — the period evaluated

  // Structured data for the UI / downstream rules
  payloadJson    Json

  // Lifecycle
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  acknowledgedAt DateTime?
  resolvedAt     DateTime?
  acknowledgedBy String?       // userId

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Deduplication: one alert per (org, type, entity, period)
  @@unique([organizationId, type, entityKey, period])
  @@index([organizationId, status, severity])
  @@index([organizationId, module, period])
  @@index([organizationId, period])
}

// ─────────────────────────────────────────────────────────────────────────────
// Universal Connector Layer
// ─────────────────────────────────────────────────────────────────────────────

enum ConnectorStatus {
  ACTIVE
  INACTIVE
  SYNCING
  ERROR
}

enum ConnectorRunStatus {
  RUNNING
  SUCCESS
  PARTIAL   // completed but some rows errored
  FAILED
}

/// A configured integration instance per org.
/// config stores source-specific credentials + settings as JSON.
/// IMPORTANT: encrypt sensitive fields (API keys, tokens) before storing.
model Connector {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  source         String          // "sag_pya" | "shopify" | "hubspot" | "csv" | …
  name           String          // human-readable label ("Shopify Store A")
  status         ConnectorStatus @default(INACTIVE)

  config         Json            @default("{}")
  modules        String[]        // enabled modules: ["orders","customers",…]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  runs           ConnectorRun[]
  cursors        ConnectorCursor[]
  mappings       ConnectorMapping[]

  @@unique([organizationId, source, name])
  @@index([organizationId, source])
  @@index([organizationId, status])
}

/// Observability record for a single module sync execution.
model ConnectorRun {
  id             String             @id @default(cuid())
  connectorId    String
  connector      Connector          @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  organizationId String

  source         String
  module         String

  startedAt      DateTime           @default(now())
  finishedAt     DateTime?

  status         ConnectorRunStatus @default(RUNNING)

  rowsRead       Int                @default(0)
  rowsImported   Int                @default(0)
  rowsSkipped    Int                @default(0)
  rowsErrored    Int                @default(0)

  cursorBefore   String?
  cursorAfter    String?

  error          String?
  meta           Json?

  @@index([connectorId, module])
  @@index([organizationId, source, module])
  @@index([organizationId, status])
  @@index([startedAt])
}

/// Persists incremental sync position per connector × module.
model ConnectorCursor {
  id             String    @id @default(cuid())
  connectorId    String
  connector      Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  organizationId String

  module         String
  cursor         String    // opaque — ISO date, page token, offset, …

  updatedAt      DateTime  @updatedAt

  @@unique([connectorId, module])
  @@index([organizationId, module])
}

/// Field-level mapping between source schema and unified schema.
/// Drives future field-mapping UI — not used by the sync engine directly yet.
model ConnectorMapping {
  id             String    @id @default(cuid())
  connectorId    String
  connector      Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  organizationId String

  module         String    // "orders" | "customers" | …
  sourceField    String    // field path in the source record
  targetField    String    // field path in the unified schema
  transform      String?   // optional expression: "toUpperCase", "parseDate:yyyy-MM-dd"
  defaultValue   String?   // fallback when source field is null/absent

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([connectorId, module, sourceField])
  @@index([connectorId, module])
}

// ─────────────────────────────────────────────────────────────────────────────
// Customer 360 + Pipeline Intelligence
// ─────────────────────────────────────────────────────────────────────────────

enum CustomerStatus {
  ACTIVE
  INACTIVE
  PROSPECT
  CHURNED
  BLOCKED
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
  ABANDONED
}

enum ActivityType {
  CALL
  EMAIL
  VISIT
  NOTE
  MEETING
  QUOTE_SENT
  DEMO
  PROPOSAL
  OTHER
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

/// Materialized canonical customer profile.
/// Merged from ERP (identity + financial) and CRM (relational + commercial).
/// slug = toSlug(nit ?? name) — used as the stable dedup key.
model CustomerProfile {
  id             String         @id @default(cuid())
  organizationId String

  // Source IDs
  erpId          String?        // SAG/ERP customer ID
  crmId          String?        // CRM customer ID

  // Identity
  nit            String?        // NIT normalizado (sin puntos/guiones)
  slug           String         // stable slug for joins + dedup
  name           String
  legalName      String?

  // Classification
  status         CustomerStatus @default(ACTIVE)
  segment        String?        // "A" | "B" | "C" | custom
  customerType   String         @default("B2B") // "B2B" | "B2C"

  // Contact
  email          String?
  phone          String?
  city           String?
  department     String?        // departamento colombiano
  address        String?

  // Commercial assignment
  sellerSlug     String?
  sellerName     String?

  // Financial KPIs (denormalized from SaleRecord — refreshed on sync)
  ltv            Decimal?       @db.Decimal(18, 2)  // lifetime value COP
  lastPurchaseAt DateTime?
  purchasePeriods Int           @default(0)          // distinct YYYYMM periods with sales
  avgMonthlyRevenue Decimal?    @db.Decimal(18, 2)
  avgTicket      Decimal?       @db.Decimal(18, 2)
  totalSalesL12  Decimal?       @db.Decimal(18, 2)   // last 12 months

  // Receivables summary (from ERP — refreshed on receivables sync)
  totalReceivable   Decimal?    @db.Decimal(18, 2)
  overdueReceivable Decimal?    @db.Decimal(18, 2)
  maxDpd            Int?        // max days past due (0 = current)

  // AI / Health scoring
  healthScore    Int?           // 0-100 (100 = healthiest)
  riskScore      Int?           // 0-100 (100 = highest risk)
  churnRisk      String?        // "LOW" | "MEDIUM" | "HIGH" | "CRITICAL"
  nextBestAction String?        // AI-suggested next step
  aiSummary      String?        // short AI-generated narrative
  scoredAt       DateTime?

  // Sync audit
  erpSyncedAt    DateTime?
  crmSyncedAt    DateTime?
  rawErpJson     Json?
  rawCrmJson     Json?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  crmOpportunities   CRMOpportunity[]
  activities         CRMActivity[]
  quotes             CRMQuote[]
  receivables        CustomerReceivable[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@index([organizationId, sellerSlug])
  @@index([organizationId, lastPurchaseAt])
  @@index([organizationId, nit])
  @@index([organizationId, churnRisk])
  @@index([organizationId, customerType])
}

/// Cartera / accounts receivable from ERP.
/// One row per invoice document with a pending balance.
model CustomerReceivable {
  id             String   @id @default(cuid())
  organizationId String
  customerId     String?  // FK to CustomerProfile (null if not yet linked)

  // Source
  erpId          String?  // ERP receivable / document ID
  invoiceNumber  String?

  // Identity fallback (when customer not yet linked)
  customerNit    String?
  customerName   String

  // Amounts (COP)
  originalAmount Decimal  @db.Decimal(18, 2)
  paidAmount     Decimal  @db.Decimal(18, 2) @default(0)
  balanceDue     Decimal  @db.Decimal(18, 2)
  currency       String   @default("COP")

  // Dates
  invoiceDate    DateTime
  dueDate        DateTime
  paidAt         DateTime?

  // Aging
  daysOverdue    Int      @default(0)
  agingBucket    String   // "CURRENT" | "1-30" | "31-60" | "61-90" | "90+"

  // Status
  status         String   @default("OPEN") // "OPEN" | "PARTIAL" | "PAID" | "WRITTEN_OFF"

  // Audit
  rawErpJson     Json?
  syncedAt       DateTime @default(now())

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       CustomerProfile? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@unique([organizationId, erpId])
  @@index([organizationId, status])
  @@index([organizationId, customerNit])
  @@index([organizationId, customerId])
  @@index([organizationId, dueDate])
  @@index([organizationId, agingBucket])
}

/// CRM pipeline opportunity.
/// Source-agnostic: populated from CRM connector syncs.
model CRMOpportunity {
  id             String            @id @default(cuid())
  organizationId String
  customerId     String?

  // Source
  crmId          String?

  // Core
  title          String
  stage          String            // matches PipelineStage.key
  amount         Decimal           @db.Decimal(18, 2)
  currency       String            @default("COP")
  probability    Int               @default(50) // 0-100, stage-based

  // Dates
  openedAt       DateTime
  expectedCloseAt DateTime?
  closedAt       DateTime?
  lastActivityAt DateTime?

  // Outcome
  status         OpportunityStatus @default(OPEN)
  lossReason     String?
  lossNote       String?

  // Assignment
  sellerSlug     String?
  sellerName     String?

  // AI scoring
  aiCloseProbability Float?        // 0–1, refreshed by scoring job
  riskFlags      String[]          // ["no_activity_14d", "competitor_mentioned", ...]

  // Audit
  rawCrmJson     Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       CustomerProfile? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  activities     CRMActivity[]
  quotes         CRMQuote[]

  @@unique([organizationId, crmId])
  @@index([organizationId, stage, status])
  @@index([organizationId, sellerSlug, status])
  @@index([organizationId, expectedCloseAt])
  @@index([organizationId, status])
  @@index([organizationId, customerId])
}

/// CRM activity log: calls, visits, emails, notes, meetings.
model CRMActivity {
  id             String       @id @default(cuid())
  organizationId String
  customerId     String?
  opportunityId  String?

  // Source
  crmId          String?

  // Core
  type           ActivityType
  subject        String?
  body           String?
  outcome        String?

  // Timing
  occurredAt     DateTime
  dueAt          DateTime?
  completedAt    DateTime?

  // Assignment
  sellerSlug     String?
  sellerName     String?

  // Audit
  rawCrmJson     Json?
  createdAt      DateTime     @default(now())

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       CustomerProfile? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  opportunity    CRMOpportunity?  @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  @@unique([organizationId, crmId])
  @@index([organizationId, customerId, occurredAt])
  @@index([organizationId, opportunityId])
  @@index([organizationId, occurredAt])
  @@index([organizationId, sellerSlug])
}

/// CRM quotes/proposals sent to customers.
model CRMQuote {
  id             String      @id @default(cuid())
  organizationId String
  customerId     String?
  opportunityId  String?

  // Source
  crmId          String?

  // Core
  quoteNumber    String?
  status         QuoteStatus @default(DRAFT)
  amount         Decimal     @db.Decimal(18, 2)
  currency       String      @default("COP")

  // Dates
  issuedAt       DateTime
  expiresAt      DateTime?
  respondedAt    DateTime?

  // Assignment
  sellerSlug     String?
  sellerName     String?

  // Audit
  rawCrmJson     Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       CustomerProfile? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  opportunity    CRMOpportunity?  @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  @@unique([organizationId, crmId])
  @@index([organizationId, customerId])
  @@index([organizationId, status])
  @@index([organizationId, sellerSlug])
  @@index([organizationId, issuedAt])
}

// ── SAG Write Layer ───────────────────────────────────────────────────────────

/// Audit trail for every SAG write operation.
/// Operations must be APPROVED by a human before execution.
/// Status lifecycle: PENDING → APPROVED → SENDING → SUCCEEDED|FAILED
///                   PENDING → REJECTED  (terminal, no execution)
///                   FAILED  → APPROVED  (retry, max 3 times)
model SagWriteOperation {
  id             String @id @default(cuid())
  organizationId String

  // Write type: 1=Cliente, 2=Documento, 3=Tercero, 5=Artículo, 6=Recibo, 28=Doc genérico
  writeType      Int

  // Status
  status         String // PENDING|APPROVED|REJECTED|SENDING|SUCCEEDED|FAILED

  // Risk classification: LOW|MEDIUM|HIGH (derived from writeType at enqueue time)
  risk           String

  // Human-readable description of what this operation does
  description    String
  // Optional reference to the source entity (e.g. customerId, orderId)
  sourceRef      String?

  // Input as stored JSON (for re-display in approval UI)
  inputJson      Json

  // XML generated at enqueue time (reviewer-inspectable before approval)
  generatedXml   String @db.Text
  // XML actually sent (copied from generatedXml at SENDING transition)
  submittedXml   String? @db.Text

  // SAG response
  sagResponseRaw String? @db.Text
  sagResponseOk  Boolean?

  // Audit trail
  initiatedBy    String  // userId or system identifier
  initiatedAt    DateTime @default(now())

  approvedBy     String?
  approvedAt     DateTime?

  rejectedBy     String?
  rejectedAt     DateTime?
  rejectionReason String?

  sentAt         DateTime?
  // Set when execution completes (SUCCEEDED or FAILED) — covers both SAG-level
  // errors (markResult) and network/SOAP errors (markFailed). Together with
  // sentAt this gives the full round-trip window for each attempt.
  executedAt     DateTime?

  retryCount     Int      @default(0)
  lastError      String?  @db.Text

  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([organizationId, initiatedAt])
  @@index([organizationId, writeType])
}

/// Configurable pipeline funnel stages per org.
/// Seed default stages on first setup; admins can customise labels/order.
model PipelineStage {
  id             String  @id @default(cuid())
  organizationId String
  key            String  // slug: "prospect" | "qualified" | "proposal" | "negotiation" | "closed_won" | "closed_lost"
  label          String
  order          Int
  isWon          Boolean @default(false)
  isLost         Boolean @default(false)
  color          String? // hex color for Kanban/pipeline UI
  probability    Int     @default(50) // default win probability for deals in this stage

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId, order])
}

// ──────────────────────────────────────────────────────────────────────────────
// §Workforce (future) — GOCEN integration preparation
//
// STATUS: NOT YET MIGRATED — these models are documented here so the
//         Prisma schema grows in one logical place.  Run
//         `npx prisma migrate dev --name add_workforce_models` once GOCEN
//         credentials are available and the adapter is implemented.
//
/// --------------------
/// Action Layer — Agentik Centro de Acciones
/// --------------------
/// Phase 1: internal tracked work items. No external side-effects yet.
/// Phase 2+: WhatsApp, SAG writebacks, GOCEN execution via payloadJson.
model ActionTask {
  id             String              @id @default(cuid())
  organizationId String

  title          String
  description    String?

  actionType     ActionTaskType
  targetType     String?             // "customer" | "seller" | "report" | "alert" | "branch" | ...
  targetId       String?             // CustomerProfile.id, seller slug, etc.
  targetLabel    String?             // Human-readable: customer name, seller name, ...

  sourceModule   String?             // "agentik_copilot" | "customer_360" | "bandeja_acciones" | "torre_de_control" | ...

  status         ActionTaskStatus    @default(PENDING)
  priority       ActionTaskPriority  @default(MEDIUM)

  assignedTo     String?             // User name/email (freeform Phase 1)
  createdBy      String              // User email who created the action

  dueAt          DateTime?
  completedAt    DateTime?

  payloadJson    Json?               // Input context snapshot
  resultJson     Json?               // Outcome data when completed
  errorMessage   String?             // Failure reason

  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  notifications     Notification[]
  scheduledReport   ScheduledReport?

  @@index([organizationId, status])
  @@index([organizationId, actionType])
  @@index([organizationId, priority, status])
  @@index([organizationId, createdAt])
}

/// --------------------
/// Sprint 4 — Internal Notifications
/// --------------------
model Notification {
  id             String           @id @default(cuid())
  organizationId String
  recipientEmail String           // user to notify
  type           NotificationType
  title          String
  body           String?
  actionTaskId   String?          // optional link to the triggering ActionTask
  isRead         Boolean          @default(false)
  readAt         DateTime?
  createdAt      DateTime         @default(now())

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actionTask     ActionTask?      @relation(fields: [actionTaskId], references: [id], onDelete: SetNull)

  @@index([organizationId, recipientEmail, isRead])
  @@index([organizationId, createdAt])
}

/// --------------------
/// Sprint 4 — Scheduled Reports
/// --------------------
model ScheduledReport {
  id             String            @id @default(cuid())
  organizationId String
  actionTaskId   String?           @unique  // optional link to the PROGRAMAR_INFORME ActionTask
  createdBy      String

  title          String
  query          String            // natural-language query passed to interpret()
  reportType     String?           // preset slug: "executive_weekly" | "cartera_aging" | "alertas_criticas" | null
  frequency      ScheduleFrequency @default(ONCE)
  isActive       Boolean           @default(true)
  recipients     String?           @db.Text  // comma-separated email list

  // Execution scheduling
  nextRunAt      DateTime?         // when to run next
  lastRunAt      DateTime?
  lastResult     Json?             // condensed ReportResult summary
  lastError      String?
  runCount       Int               @default(0)

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actionTask     ActionTask?       @relation(fields: [actionTaskId], references: [id], onDelete: SetNull)

  @@index([organizationId, isActive, nextRunAt])
  @@index([organizationId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Finance V2 — FP&A (Planeación y Presupuesto)
// ─────────────────────────────────────────────────────────────────────────────

enum BudgetPeriod {
  ANNUAL
  QUARTERLY
  MONTHLY
}

enum BudgetDimension {
  TOTAL     // org-wide total
  BRANCH    // by store / sucursal
  CHANNEL   // by sales channel
  SELLER    // by vendedor
  LINE      // by product line
  PAYROLL   // workforce/nómina (future-ready)
}

/// Budget target for a given period, dimension, and cost/revenue category.
/// Used by FP&A variance analysis to compare plan vs actual (SaleRecord actuals).
model Budget {
  id             String          @id @default(cuid())
  organizationId String

  // Period
  year           Int
  month          Int?            // null when periodType = ANNUAL or QUARTERLY
  quarter        Int?            // 1-4; null when periodType = ANNUAL or MONTHLY
  periodType     BudgetPeriod

  // Dimension
  dimension      BudgetDimension
  dimensionKey   String          @default("total")  // storeSlug, channel enum, sellerSlug, productLine, "total"
  dimensionLabel String          @default("Total")

  // Category — what kind of budget line
  // "revenue" | "cogs" | "opex" | "payroll" | "capex" | "marketing"
  category       String          @default("revenue")

  // Amount
  amount         Decimal         @db.Decimal(18, 2)
  currency       String          @default("COP")

  notes          String?
  createdBy      String          // email of the user who set the target

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // One target per org / period / dimension / dimensionKey / category
  @@unique([organizationId, year, month, quarter, periodType, dimension, dimensionKey, category])
  @@index([organizationId, year, periodType])
  @@index([organizationId, dimension, dimensionKey])
}

/// --------------------
/// WhatsApp Module (tenant-activatable)
/// --------------------

enum WaConversationStatus {
  ACTIVE
  RESOLVED
  HANDED_OFF
  TIMED_OUT
}

enum WaMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

/// Intent classified from the incoming message text.
/// Extend this enum as new intent categories are needed.
enum WaIntent {
  FAQ
  APPOINTMENT
  SALES
  SUPPORT
  HANDOFF
  UNKNOWN
}

/// Per-org WhatsApp Business configuration.
/// One record per organization. Stores Meta credentials, display config,
/// and a JSON blob for per-intent settings (FAQs, schedules, escalation rules).
/// Active flag controls whether the webhook processes messages for this org.
model WhatsAppConfig {
  id             String  @id @default(cuid())
  organizationId String  @unique

  /// Meta Cloud API phone_number_id for routing
  phoneNumberId  String
  /// WhatsApp Business Account ID (WABA)
  wabaId         String
  /// Webhook verify token set in Meta App Dashboard
  webhookSecret  String

  /// Business display name sent in AI greetings
  displayName    String
  /// Optional first-contact welcome message
  welcomeMessage String?
  /// Extensible per-intent config blob:
  ///   { faq: [{q, a}], appointment: { calendarUrl }, escalation: { email } }
  intentConfig   Json?
  /// Brand voice and style configuration blob:
  ///   { tone, useEmoji, closingStyle, forbiddenPhrases, signaturePhrases,
  ///     salesStyleHints, escalationStyle }
  brandConfig    Json?
  /// false = draft / paused; webhook silently acks but does not process
  active         Boolean @default(false)

  organization  Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations WhatsAppConversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// One conversation per (organizationId, contactPhone) pair.
/// Automatically resumed when the same number writes again while ACTIVE.
model WhatsAppConversation {
  id             String               @id @default(cuid())
  organizationId String
  configId       String

  /// Sender phone in E.164 format, e.g. +573001234567
  contactPhone   String
  /// WhatsApp profile display name — updated on each contact if present
  contactName    String?

  status         WaConversationStatus @default(ACTIVE)
  /// Most recent intent — updated after every incoming message
  lastIntent     WaIntent?
  handedOff      Boolean              @default(false)
  /// Department or agent identifier when status = HANDED_OFF
  handoffTo      String?

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  config       WhatsAppConfig    @relation(fields: [configId], references: [id], onDelete: Cascade)
  messages     WhatsAppMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, contactPhone])
  @@index([organizationId, status])
  @@index([organizationId, updatedAt])
  @@index([configId])
}

/// Individual message within a WhatsApp conversation.
model WhatsAppMessage {
  id             String        @id @default(cuid())
  conversationId String
  /// Denormalized for fast per-org queries without a join
  organizationId String

  role           WaMessageRole
  /// Normalized plain-text content (images → "[imagen]", voice → "[audio]")
  content        String
  /// Classified intent — set only on USER messages
  intent         WaIntent?
  /// Full raw Meta webhook entry — preserved for audit and debugging
  rawPayload     Json?
  /// Meta-assigned wamid — used for deduplication (idempotent upsert)
  waMessageId    String?       @unique

  conversation WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([organizationId, intent])
  @@index([organizationId, createdAt])
}

/// Lightweight per-contact memory for personalization and outcome tracking.
/// One record per (organizationId, contactPhone) pair — contact-scoped, org-isolated.
/// Written asynchronously after the webhook pipeline — never blocks the 200 response.
model WhatsAppContactMemory {
  id             String   @id @default(cuid())
  organizationId String
  contactPhone   String

  /// Most recently detected display name from WhatsApp profile
  contactName              String?
  /// Last intent that produced a tracked outcome: "SALES" or "APPOINTMENT"
  lastSuccessfulOutcome    String?
  /// Timestamp of that outcome
  lastSuccessfulOutcomeAt  DateTime?
  /// Free-text product or service keyword from last SALES conversation
  lastProductMention       String?
  /// Time hint from last APPOINTMENT request, e.g. "Mañana por la tarde"
  lastAppointmentRequest   String?
  /// Timestamp of last HANDOFF event
  lastHandoffAt            DateTime?
  /// Total distinct conversation threads opened (incremented on first message per thread)
  totalConversations       Int      @default(1)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, contactPhone])
  @@index([organizationId])
}

// ── Marketing Studio ──────────────────────────────────────────────────────────

enum StudioSessionDbStatus {
  IDLE
  IN_PROGRESS
  PENDING_REVIEW
  APPROVED
  REJECTED
  PUBLISHING
  PUBLISHED
  FAILED
}

enum AssetGenerationStatus {
  PENDING
  QUEUED
  GENERATING
  READY
  FAILED
}

enum AssetPublishStatus {
  NONE
  QUEUED
  PUBLISHING
  PUBLISHED
  FAILED
}

/// Persistent record of a Marketing Studio wizard session.
/// One session = one operator run through the 5-step wizard.
model StudioSession {
  /// Client-generated sortable ID (format: ss_<timestamp36><rand>)
  id              String                @id
  organizationId  String
  tenantId        String
  /// Current wizard step — mirrors StudioStep TS union literal
  step            String
  status          StudioSessionDbStatus @default(IDLE)
  /// UserObjective literal — set after step 2
  objective       String?
  productSku      String?
  productImageUrl String?
  /// Serialised Partial<MinimumInputFields>
  inputsJson      Json?
  /// Serialised ReviewItem[] — snapshot at review step
  reviewItemsJson Json?
  /// Serialised PublishResult — set after execution succeeds
  publishResultJson Json?
  /// Job ID returned by the executor stub / n8n webhook
  executionJobId  String?
  /// Full N8nWebhookPayload snapshot sent to the executor
  executionPayloadJson Json?

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assets       GeneratedAsset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, tenantId, createdAt(sort: Desc)])
}

/// One generated asset produced within a StudioSession.
/// Maps to OutputAssetType — each session produces N assets per workflow profile.
model GeneratedAsset {
  id               String                @id @default(cuid())
  sessionId        String
  /// OutputAssetType literal: product_photo | social_image | social_video | copy_caption | hashtags | product_draft
  assetType        String
  generationStatus AssetGenerationStatus @default(PENDING)
  publishStatus    AssetPublishStatus    @default(NONE)
  /// CDN URL for visual assets once generated
  assetUrl         String?
  /// Body for text assets (copy_caption, hashtags)
  content          String?
  /// Operator review decision — pending | approved | rejected
  reviewStatus     String                @default("pending")
  /// External reference: Shopify draft ID, Luca job ID, catalog export URL
  externalRef      String?
  /// Provider job ID from the generation provider
  generationJobId  String?
  /// Provider-specific extra data
  providerMeta     Json?

  session StudioSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([sessionId, generationStatus])
}

