// ─── Agentik Task System ──────────────────────────────────────────────────────
//
// Universal task persistence for Agentik OS.
// Created by Copilot agents and operational modules.
// No FK constraints to domain entities yet — kept flexible for cross-module use.
//
// Sprint: AGENTIK-TASK-PERSISTENCE-01

model Task {
  id              String   @id @default(cuid())
  organizationId  String

  // ── Draft reference ──────────────────────────────────────────────────────
  draftId         String?

  // ── Core content ─────────────────────────────────────────────────────────
  title           String
  description     String?

  // ── Classification ────────────────────────────────────────────────────────
  priority        String                // low | medium | high | critical
  status          String  @default("open")   // open | in_progress | waiting | blocked | completed | cancelled
  source          String                // copilot | manual | finance | collections | commercial | marketing | inventory | operations | system
  category        String  @default("general") // followup | review | approval | investigation | reconciliation | customer | document | report | alert | general
  visibility      String  @default("organization") // private | team | organization

  // ── Ownership ────────────────────────────────────────────────────────────
  ownerType       String                // user | agent | team | role | system
  ownerId         String
  ownerLabel      String

  // ── Assignment (optional) ─────────────────────────────────────────────────
  assignedType    String?
  assignedId      String?
  assignedLabel   String?

  // ── Context ───────────────────────────────────────────────────────────────
  module          String?               // e.g. "conciliacion", "tesoreria"
  entityType      String?               // e.g. "copilot_action", "module"
  entityId        String?               // reference to originating entity

  // ── Scheduling ────────────────────────────────────────────────────────────
  dueAt           DateTime?

  // ── Metadata ─────────────────────────────────────────────────────────────
  metadataJson    Json?

  // ── Provenance ───────────────────────────────────────────────────────────
  createdBy       String                // agentId or userId

  // ── Timestamps ───────────────────────────────────────────────────────────
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?
  cancelledAt     DateTime?

  // ── Idempotency — AGENTIK-IDEMPOTENCY-01 ─────────────────────────────────
  idempotencyKey  String?   // Partial unique index in migration (WHERE IS NOT NULL)

  // ── Relations ────────────────────────────────────────────────────────────
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // ── Indexes ──────────────────────────────────────────────────────────────
  @@index([organizationId])
  @@index([status])
  @@index([priority])
  @@index([source])
  @@index([category])
  @@index([createdAt])
  @@index([ownerId])
  @@index([assignedId])
  @@index([module])
  @@index([entityId])
  @@index([idempotencyKey])
  @@index([organizationId, status])
  @@index([organizationId, priority])
  @@index([organizationId, createdAt])
}

// ── Approvals ─────────────────────────────────────────────────────────────────

model Approval {
  id                  String    @id

  organizationId      String

  // ── Core content ────────────────────────────────────────────────────────────
  title               String
  description         String?

  // ── Classification ───────────────────────────────────────────────────────────
  status              String                // PENDING | APPROVED | REJECTED | CANCELLED | EXPIRED
  priority            String                // LOW | MEDIUM | HIGH | CRITICAL
  category            String                // FINANCIAL | COLLECTIONS | COMMERCIAL | etc.
  source              String                // COPILOT | AGENT | MODULE | USER | SYSTEM

  // ── Requestor ────────────────────────────────────────────────────────────────
  requestorType       String
  requestorId         String?
  requestorLabel      String?

  // ── Approver ─────────────────────────────────────────────────────────────────
  approverType        String
  approverId          String?
  approverLabel       String?

  // ── Context (flat denormalized columns) ──────────────────────────────────────
  module              String?
  entityType          String?
  entityId            String?
  navigationTarget    String?
  impactSummary       String?
  recommendation      String?

  // ── JSON blobs ───────────────────────────────────────────────────────────────
  businessContextJson Json?
  relationshipsJson   Json?
  auditTrailJson      Json?
  decisionJson        Json?
  metadataJson        Json?

  // ── Timestamps ───────────────────────────────────────────────────────────────
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  expiresAt           DateTime?
  decidedAt           DateTime?
  cancelledAt         DateTime?
  expiredAt           DateTime?

  // ── Idempotency — AGENTIK-IDEMPOTENCY-01 ─────────────────────────────────────
  idempotencyKey      String?   // Partial unique index in migration (WHERE IS NOT NULL)

  // ── Relations ────────────────────────────────────────────────────────────────
  organization        Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workExecutions      WorkExecution[]

  // ── Indexes ──────────────────────────────────────────────────────────────────
  @@index([organizationId])
  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([source])
  @@index([createdAt])
  @@index([requestorId])
  @@index([approverId])
  @@index([module])
  @@index([entityType, entityId])
  @@index([idempotencyKey])
}

// ─────────────────────────────────────────────────────────────────────────────
// WorkExecution — AGENTIK-WORK-EXECUTION-LIVE-01
// Records every real work execution triggered by an approved Approval.
// ─────────────────────────────────────────────────────────────────────────────

model WorkExecution {
  id                  String    @id

  organizationId      String
  approvalId          String

  // ── Executor ─────────────────────────────────────────────────────────────────
  executorType        String    // TASK_ASSIGNMENT | REPORT_GENERATION | DOCUMENT_GENERATION | etc.
  trigger             String    // APPROVAL_APPROVED | MANUAL | SCHEDULED | WEBHOOK | SYSTEM
  // ── Module executor routing — AGENTIK-MULTI-MODULE-EXECUTORS-01 ──────────────
  module              String?   // finanzas | cobranza | comercial | marketing | etc.
  actionType          String?   // RECONCILIATION | PAYMENT_PLAN | ORDER_RELEASE | etc.

  // ── Status ───────────────────────────────────────────────────────────────────
  status              String    // PENDING | QUEUED | RUNNING | COMPLETED | FAILED | CANCELLED
  success             Boolean?

  // ── Message / result ─────────────────────────────────────────────────────────
  message             String?
  durationMs          Int?

  // ── JSON payloads ────────────────────────────────────────────────────────────
  payloadJson         Json?     // WorkExecutionPayload
  resultJson          Json?     // WorkExecutionResult
  auditTrailJson      Json?     // WorkExecutionAudit[]
  errorsJson          Json?     // WorkExecutionError[]

  // ── Retry ────────────────────────────────────────────────────────────────────
  retryOfExecutionId  String?
  retryAttempt        Int       @default(0)
  maxRetryAttempts    Int       @default(3)
  retryReason         String?
  retriedByJson       Json?
  retriedAt           DateTime?

  // ── Timestamps ───────────────────────────────────────────────────────────────
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  startedAt           DateTime?
  completedAt         DateTime?
  failedAt            DateTime?

  // ── Relations ────────────────────────────────────────────────────────────────
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  approval            Approval     @relation(fields: [approvalId], references: [id], onDelete: Cascade)

  // ── Indexes ──────────────────────────────────────────────────────────────────
  @@index([organizationId])
  @@index([approvalId])
  @@index([status])
  @@index([executorType])
  @@index([module])
  @@index([actionType])
  @@index([createdAt])
  @@index([retryOfExecutionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// WorkflowRun — AGENTIK-WORKFLOW-CHAINING-01
// Live instance of an executing workflow chain.
// Steps and audit trail stored as JSON for fast iteration.
// ─────────────────────────────────────────────────────────────────────────────

model WorkflowRun {
  id                  String    @id

  organizationId      String
  chainId             String    // FINANCE_RECONCILIATION_CHAIN | COMMERCIAL_PORTFOLIO_CHAIN | etc.
  chainName           String

  status              String    // PENDING | RUNNING | COMPLETED | FAILED | CANCELLED | BLOCKED

  // ── Idempotency ──────────────────────────────────────────────────────────────
  // Deterministic key: "workflow:${chainId}:${triggerExecutionId}"
  // Partial unique index in DB (see migration) prevents duplicate runs
  // under concurrent load. Not declared @unique here — handled via raw index.
  idempotencyKey      String?

  // ── Trigger ──────────────────────────────────────────────────────────────────
  triggerExecutionId  String    // WorkExecution that started the chain
  triggerApprovalId   String?   // ApprovalRequest that led to the trigger execution

  // ── Current position ─────────────────────────────────────────────────────────
  currentStepId       String?   // Step currently running or waiting

  // ── JSON state ───────────────────────────────────────────────────────────────
  stepsJson           Json?     // WorkflowStepResult[]
  auditTrailJson      Json?     // WorkflowChainAuditEvent[]
  metadataJson        Json?     // arbitrary metadata

  // ── Timestamps ───────────────────────────────────────────────────────────────
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  completedAt         DateTime?
  failedAt            DateTime?

  // ── Relations ────────────────────────────────────────────────────────────────
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // ── Indexes ──────────────────────────────────────────────────────────────────
  @@index([organizationId])
  @@index([chainId])
  @@index([status])
  @@index([triggerExecutionId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// AiUsage — AGENTIK-AI-BILLING-FOUNDATION-01
// Records every AI operation for cost tracking and credit debit.
// Clients see credits only — costUsd is internal.
// ─────────────────────────────────────────────────────────────────────────────

model AiUsage {
  id                    String    @id @default(cuid())

  organizationId        String
  orgSlug               String

  moduleSlug            String?
  agentId               String?
  agentDisplayName      String?

  /// Fine-grained feature key: "reconciliation:auto_match", "copilot:explain", etc.
  featureKey            String

  workflowRunId         String?
  workExecutionId       String?
  autonomousOperationId String?
  copilotSessionId      String?

  /// Provider slug: "anthropic" | "openai" | "gemini" | "mock"
  provider              String?
  /// Model identifier: "claude-sonnet-4-6" | "gpt-4o" | "mock"
  model                 String?

  /// AiUsageKind: TEXT_GENERATION | JSON_REASONING | IMAGE_GENERATION | etc.
  usageKind             String

  inputTokens           Int       @default(0)
  outputTokens          Int       @default(0)
  totalTokens           Int       @default(0)

  imageUnits            Int?
  videoSeconds          Int?
  audioSeconds          Int?

  requestCount          Int       @default(1)

  /// Provider cost in USD — INTERNAL ONLY. Never show to tenants.
  costUsd               Decimal?  @db.Decimal(12, 6)
  /// ESTIMATED | ACTUAL | MANUAL
  costMode              String

  /// Agentik credits consumed — the commercial unit shown to tenants.
  creditsUsed           Int       @default(0)

  /// RECORDED | ESTIMATED | RECONCILED | VOIDED | FAILED
  status                String

  metadataJson          Json?

  createdAt             DateTime  @default(now())

  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([orgSlug])
  @@index([moduleSlug])
  @@index([agentId])
  @@index([featureKey])
  @@index([usageKind])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// AiCreditLedger — AGENTIK-AI-BILLING-FOUNDATION-01
// Immutable ledger of credit movements per organization.
// Balance = sum of all entries for the org (positive = grant, negative = debit).
// ─────────────────────────────────────────────────────────────────────────────

model AiCreditLedger {
  id                String    @id @default(cuid())

  organizationId    String
  orgSlug           String

  /// PURCHASE | MONTHLY_GRANT | USAGE_DEBIT | REFUND | MANUAL_ADJUSTMENT | EXPIRATION | PROMO_CREDIT
  type              String

  /// Credit delta. Positive = grant. Negative = debit.
  credits           Int

  /// Running balance after this entry (populated at write time).
  balanceAfter      Int?

  relatedUsageId    String?
  relatedInvoiceId  String?

  reason            String?
  createdBy         String?

  /// Idempotency key. Unique (nulls allowed). Prevents double debits/grants.
  correlationId     String?   @unique

  metadataJson      Json?

  createdAt         DateTime  @default(now())

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([orgSlug])
  @@index([type])
  @@index([createdAt])
}
// ─────────────────────────────────────────────────────────────────────────────
// AiCreditBalance — AGENTIK-AI-BILLING-HARDENING-01
// Stored running balance per organization.
// Updated atomically inside Prisma $transaction alongside the ledger write.
// Single source of truth for current balance — no need to replay full ledger.
// Reconstruction: replay AiCreditLedger entries if this table is ever corrupted.
// ─────────────────────────────────────────────────────────────────────────────

model AiCreditBalance {
  id             String   @id @default(cuid())

  orgSlug        String   @unique
  organizationId String   @unique

  /// Current credit balance. Updated atomically with every ledger write.
  balance        Int      @default(0)

  /// Cumulative totals for integrity cross-checking.
  totalGranted   Int      @default(0)
  totalDebited   Int      @default(0)
  totalRefunded  Int      @default(0)

  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// AiProvider — AGENTIK-AI-PRICING-ENGINE-01
// Describes an AI provider (OpenAI, Anthropic, Google, Runway, etc.).
// No API credentials here — those live in the vault.
// This is pricing metadata only.
// ─────────────────────────────────────────────────────────────────────────────

model AiProvider {
  id                   String   @id
  name                 String
  kind                 String
  status               String
  defaultCurrency      String   @default("USD")
  supportsTokenBilling Boolean  @default(true)
  supportsUnitBilling  Boolean  @default(false)
  supportsStreaming     Boolean  @default(false)
  metadataJson         Json?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  modelRates           AiModelRate[]

  @@index([kind])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// AiModelRate — AGENTIK-AI-PRICING-ENGINE-01
// Pricing rate for a specific provider + model + usageKind combination.
// All USD costs are internal — tenants see credits only.
// effectiveTo = null means the rate never expires.
// Use modelId = "default" for provider-level fallback rates.
// Use providerId = "global" for global usageKind fallback rates.
// ─────────────────────────────────────────────────────────────────────────────

model AiModelRate {
  id                     String    @id @default(cuid())
  providerId             String
  modelId                String
  displayName            String
  usageKind              String

  currency               String    @default("USD")

  /// Provider cost per 1 million input tokens in USD.
  inputTokenCostPer1M    Decimal?  @db.Decimal(12, 6)
  /// Provider cost per 1 million output tokens in USD.
  outputTokenCostPer1M   Decimal?  @db.Decimal(12, 6)
  /// Provider cost per image unit in USD.
  imageUnitCost          Decimal?  @db.Decimal(12, 6)
  /// Provider cost per video second in USD.
  videoSecondCost        Decimal?  @db.Decimal(12, 6)
  /// Provider cost per audio second in USD.
  audioSecondCost        Decimal?  @db.Decimal(12, 6)
  /// Fixed cost per API request in USD.
  requestCost            Decimal?  @db.Decimal(12, 6)
  /// Minimum provider cost per call in USD.
  minimumProviderCostUsd Decimal?  @db.Decimal(12, 6)

  minimumCredits         Int       @default(1)
  creditMarkupMultiplier Decimal   @default(1.0) @db.Decimal(8, 4)

  effectiveFrom          DateTime  @default(now())
  effectiveTo            DateTime?
  status                 String

  metadataJson           Json?

  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  provider               AiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([modelId])
  @@index([usageKind])
  @@index([status])
  @@index([effectiveFrom])
  @@index([effectiveTo])
}

// ─────────────────────────────────────────────────────────────────────────────
// CopilotMemory — AGENTIK-COPILOT-MEMORY-PERSISTENCE-01
// Durable strategic memory for the Copilot Intelligence layer.
// Replaces the ephemeral in-memory store.
//
// Design rules:
//   - orgSlug is mandatory on every row — tenant isolation enforced at DB level.
//   - tagsJson stores string[] as JSONB — mapped by memory-prisma-mapper.ts.
//   - deletedAt implements soft delete — never physically remove a memory.
//   - title is capped at 80 chars; content at 2000 chars (enforced by mapper).
//   - type / scope / importance are stored as TEXT — validated by mapper.
// ─────────────────────────────────────────────────────────────────────────────

model CopilotMemory {
  id         String    @id @default(cuid())
  orgSlug    String
  type       String    /// MemoryType: STRATEGIC | OPERATIONAL | PREFERENCE | LEARNING
  scope      String    /// MemoryScope: TENANT | MODULE | AGENT
  importance String    /// MemoryImportance: LOW | MEDIUM | HIGH | CRITICAL
  title      String    @db.VarChar(80)
  content    String    @db.Text
  tagsJson   Json      @default("[]")
  source     String
  moduleId   String?
  agentId    String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime? /// Soft delete — NULL = active, non-null = deleted

  @@index([orgSlug])
  @@index([orgSlug, type])
  @@index([orgSlug, scope])
  @@index([orgSlug, importance])
  @@index([orgSlug, moduleId])
  @@index([orgSlug, agentId])
  @@index([deletedAt])
}

/// Standalone org-scoped secret vault.
/// AGENTIK-SECURITY-VAULT-01
/// Separate from IntegrationSecret (per-connection) — this model is scoped
/// directly to orgSlug, not to an IntegrationConnection.
/// NEVER expose encryptedValue to client layers.
model VaultSecret {
  id             String   @id @default(cuid())

  /// Tenant boundary — all queries filter by orgSlug.
  orgSlug        String

  /// Human-readable name (e.g. "OpenAI Production Key").
  name           String

  /// VaultSecretKind: API_KEY | ACCESS_TOKEN | REFRESH_TOKEN | WEBHOOK_SECRET
  ///   | CERTIFICATE_PASSWORD | SOFTWARE_PIN | OAUTH_PAIR | BANKING_CREDENTIAL | GENERIC_SECRET
  kind           String

  /// VaultSecretClassification: RESTRICTED | CONFIDENTIAL
  classification String

  /// Provider slug (e.g. "openai", "meta", "dian", "shopify").
  provider       String

  /// AES-256-GCM encrypted secret value.
  /// Format: base64( IV[12] || AuthTag[16] || Ciphertext )
  /// Encrypted by vault-encryption.ts using VAULT_MASTER_KEY.
  encryptedValue String   @db.Text

  /// Encryption key version — used for rotation tracking.
  keyVersion     Int      @default(1)

  /// Arbitrary tags for discovery (stored as String array).
  tags           String[]

  /// VaultSecretStatus: ACTIVE | DISABLED | REVOKED | EXPIRED
  status         String   @default("ACTIVE")

  /// Timestamp of last plaintext access (via VaultService.readSecret).
  lastAccessedAt DateTime?

  /// Optional expiry — secrets past this date cannot be read.
  expiresAt      DateTime?

  /// Set when status = REVOKED.
  revokedAt      DateTime?

  /// Free-form operator notes — never contains secret content.
  notes          String?   @db.Text

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([orgSlug])
  @@index([orgSlug, kind])
  @@index([orgSlug, provider])
  @@index([orgSlug, status])
  @@index([expiresAt])
}

/// Persistent, append-only security audit event log.
/// AGENTIK-SECURITY-AUDIT-PERSISTENCE-01
/// Multi-tenant — all queries filter by orgSlug.
/// NEVER store secret values, tokens, certificates, or passwords.
/// Only metadata fields are stored.
model SecurityAuditEvent {
  id           String   @id @default(cuid())

  /// Tenant owner — all queries require this field.
  orgSlug      String

  /// The action that occurred (e.g. "SECRET_READ", "ACCESS_DENIED").
  eventType    String

  /// Domain classification (e.g. "VAULT", "AUTHORIZATION").
  category     String

  /// Impact level: LOW | MEDIUM | HIGH | CRITICAL
  severity     String

  /// Resource identifier acted upon (e.g. "secret:OPENAI_API_KEY").
  resourceId   String?

  /// Resource type classification (e.g. "SECRET", "MEMORY").
  resourceType String?

  /// Human-readable resource name for display.
  resourceName String?

  /// Actor identifier who triggered the event.
  actorId      String?

  /// Actor type: USER | AGENT | SYSTEM | INTEGRATION | CRON | ANONYMOUS
  actorType    String?

  /// Human-readable actor name for display.
  actorName    String?

  /// Structured metadata — never contains secret values.
  metadata     Json

  /// Immutable creation timestamp — set at event creation, never modified.
  createdAt    DateTime @default(now())

  @@index([orgSlug])
  @@index([orgSlug, category])
  @@index([orgSlug, severity])
  @@index([orgSlug, eventType])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// AGENTIK-SECURITY-SECRET-ROTATION-01
// Secret Rotation — Rotation Record
// ─────────────────────────────────────────────────────────────────────────────

/// SecretRotation — tracks a single rotation lifecycle for a secret class.
/// Never stores secret values — metadata only.
model SecretRotation {
  /// Unique rotation identifier.
  id          String  @id @default(cuid())

  /// Tenant scope — required for multi-tenant isolation.
  orgSlug     String

  /// The secret class being rotated (from RotationRegistry).
  secretId    String

  /// Rotation strategy: MANUAL | SCHEDULED | EMERGENCY
  strategy    String

  /// Lifecycle status: PENDING | VALIDATING | READY | ACTIVE | REVOKED | FAILED | CANCELLED
  status      String  @default("PENDING")

  /// Who requested the rotation (userId or "system").
  requestedBy String

  /// Who approved the rotation (userId or null).
  approvedBy  String?

  /// Human-readable reason for the rotation.
  reason      String

  /// Structured metadata — never contains secret values or key material.
  metadata    Json    @default("{}")

  /// When the rotation was requested.
  createdAt   DateTime @default(now())

  /// When the new version was activated.
  activatedAt DateTime?

  /// When the old version was revoked.
  revokedAt   DateTime?

  /// When the rotation was completed.
  completedAt DateTime?

  @@index([orgSlug])
  @@index([orgSlug, secretId])
  @@index([orgSlug, status])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// AGENTIK-SECURITY-KMS-01
// KMS Key Metadata
// ─────────────────────────────────────────────────────────────────────────────

/// KmsKey — persists KMS key metadata for the Agentik KMS layer.
/// NEVER stores key material — only metadata and lifecycle state.
/// Multi-tenant: all queries require orgSlug.
model KmsKey {
  /// Stable unique key ID (UUID-based, generated by provider).
  keyId      String   @id

  /// Tenant boundary — all queries require this field.
  orgSlug    String

  /// Human-readable alias scoped to this tenant (e.g. "vault_master_key").
  /// Unique per (orgSlug, keyAlias).
  keyAlias   String

  /// KMS provider type: LOCAL | AWS_KMS | AZURE_KEY_VAULT | GCP_KMS | CUSTOM
  provider   String

  /// Key lifecycle status: ACTIVE | ROTATING | DISABLED | REVOKED | PENDING
  status     String   @default("ACTIVE")

  /// Current key version number. Increments on each rotation.
  version    Int      @default(1)

  /// Encryption algorithm (e.g. "AES-256-GCM").
  algorithm  String   @default("AES-256-GCM")

  /// ISO 8601 timestamp when the key was created.
  createdAt  DateTime @default(now())

  /// ISO 8601 timestamp of the last rotation. Null if never rotated.
  rotatedAt  DateTime?

  /// Optional expiry date for the key. Null if no expiry.
  expiresAt  DateTime?

  @@unique([keyId, orgSlug], name: "keyId_orgSlug")
  @@unique([orgSlug, keyAlias], name: "orgSlug_keyAlias")
  @@index([orgSlug])
  @@index([orgSlug, status])
  @@index([orgSlug, provider])
  @@index([expiresAt])
}

// ── MFA Models ─────────────────────────────────────────────────────────────────

/// MfaEnrollment — MFA enrollment metadata for a user+method.
/// NEVER stores plain secrets. encryptedSecret is always encrypted.
model MfaEnrollment {
  /// Unique enrollment ID.
  id              String   @id @default(cuid())

  /// Tenant scope.
  orgSlug         String

  /// User ID (references the user who enrolled MFA).
  userId          String

  /// MFA method: TOTP | EMAIL | SMS | PASSKEY | WEBAUTHN | RECOVERY_CODE
  method          String

  /// Lifecycle status: DISABLED | PENDING | ENABLED | LOCKED
  status          String   @default("PENDING")

  /// Encrypted TOTP secret or provider-specific encrypted credential.
  /// NEVER stored in plaintext. Encrypted via MFA Encryption integration.
  encryptedSecret String

  /// Number of consecutive failed verification attempts.
  failCount       Int      @default(0)

  createdAt       DateTime @default(now())
  enabledAt       DateTime?
  lastUsedAt      DateTime?

  @@unique([orgSlug, userId, method], name: "orgSlug_userId_method")
  @@unique([id, orgSlug], name: "id_orgSlug")
  @@index([orgSlug])
  @@index([orgSlug, userId])
  @@index([orgSlug, status])
  @@index([orgSlug, method])
}

/// MfaRecoveryCode — single-use emergency recovery code record.
/// NEVER stores plain codes. Only scrypt hashes.
model MfaRecoveryCode {
  /// Unique code record ID.
  id        String   @id @default(cuid())

  /// Tenant scope.
  orgSlug   String

  /// User ID.
  userId    String

  /// scrypt hash of the recovery code. Format: "scrypt:{saltHex}:{hashHex}".
  /// NEVER the plain code.
  codeHash  String

  /// When the code was used (null = not yet used). Single-use enforcement.
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([orgSlug])
  @@index([orgSlug, userId])
  @@index([orgSlug, userId, usedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Security Anomaly Detection — AGENTIK-SECURITY-ANOMALY-DETECTION-01
// ─────────────────────────────────────────────────────────────────────────────
//
// AnomalyAlert  — correlated actionable alert produced by the detection layer.
// AnomalySignal — single detection event from one detector.
//
// Design principles:
//   - orgSlug-scoped: all rows carry orgSlug (NOT organizationId FK) to stay
//     consistent with the security layer's tenant boundary model.
//   - Detection only: no remediation, no blocking, no session revocation.
//   - Immutable signals: signals are created once, never updated.
//   - Alerts are mutable only on status, resolvedAt, acknowledgedBy, resolvedBy.
//   - metadata / eventData stored as Json — no raw secrets, no OTP codes,
//     no key material, no recovery codes.
// ─────────────────────────────────────────────────────────────────────────────

/// Correlated security alert produced by the Anomaly Detection Engine.
/// One alert may aggregate multiple AnomalySignals (via isCorrelated flag).
/// Lifecycle: OPEN → ACKNOWLEDGED → RESOLVED | IGNORED.
model AnomalyAlert {
  /// Cuid — matches AnomalyAlert.id in domain types.
  id          String @id @default(cuid())

  /// Tenant scope — orgSlug (NOT organizationId FK).
  orgSlug     String

  /// AnomalyType string — e.g. "LOGIN_FAILURE_SPIKE", "CROSS_TENANT_ATTEMPT".
  type        String

  /// AnomalySeverity: LOW | MEDIUM | HIGH | CRITICAL.
  severity    String

  /// AnomalyStatus: OPEN | ACKNOWLEDGED | RESOLVED | IGNORED.
  status      String @default("OPEN")

  /// Human-readable title for display in dashboards and SOC workflows.
  title       String

  /// Detailed description — includes detector reasoning.
  description String

  /// 0–100 composite risk score from the risk-scoring engine.
  riskScore   Int    @default(0)

  /// True when produced by the correlation engine (multi-signal alert).
  isCorrelated Boolean @default(false)

  /// Correlation rule ID that triggered this alert (null for single-signal alerts).
  sourceRule  String?

  /// Serialized alert metadata snapshot — never contains raw secrets or keys.
  metadata    Json   @default("{}")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  resolvedAt  DateTime?

  /// userId of the operator who acknowledged the alert.
  acknowledgedBy String?
  /// userId of the operator who resolved the alert.
  resolvedBy     String?

  signals     AnomalySignal[]

  @@index([orgSlug])
  @@index([orgSlug, status])
  @@index([orgSlug, severity])
  @@index([orgSlug, type])
  @@index([orgSlug, status, severity])
  @@index([orgSlug, createdAt])
  @@index([orgSlug, riskScore])
}

/// Single detection event emitted by one AnomalyDetector.
/// Immutable after creation — never updated, only queried.
/// May be linked to an AnomalyAlert when correlated.
model AnomalySignal {
  /// Cuid — matches AnomalySignal.id in domain types.
  id          String @id @default(cuid())

  /// Tenant scope — orgSlug (NOT organizationId FK).
  orgSlug     String

  /// AnomalyType string — mirrors the detector's output type.
  type        String

  /// AnomalySeverity: LOW | MEDIUM | HIGH | CRITICAL.
  severity    String

  /// 0–100 weight assigned by the detecting rule/policy.
  weight      Int    @default(0)

  /// Human-readable reason for this signal (no raw secrets).
  reason      String

  /// Detector ID that produced this signal (e.g. "mfa-failure-detector").
  detectorId  String

  /// Serialized signal metadata — never contains raw secrets, OTP, key material.
  metadata    Json   @default("{}")

  /// ISO 8601 — when the triggering event occurred.
  occurredAt  DateTime

  /// Start of the detection time window (ISO 8601).
  windowStart DateTime

  /// End of the detection time window (ISO 8601).
  windowEnd   DateTime

  /// Optional: user ID associated with the signal (null for agent/system events).
  userId      String?

  /// Optional: agent ID (one of the MONITORED_AGENT_IDS) if signal is agent-related.
  agentId     String?

  /// Optional: session ID if signal is tied to a specific session.
  sessionId   String?

  /// Optional: resource reference (e.g. vault secret alias, KMS key alias).
  /// NEVER the actual secret value or key material.
  resource    String?

  /// Optional FK to the AnomalyAlert when this signal was correlated into an alert.
  alertId     String?
  alert       AnomalyAlert? @relation(fields: [alertId], references: [id], onDelete: SetNull)

  @@index([orgSlug])
  @@index([orgSlug, type])
  @@index([orgSlug, severity])
  @@index([orgSlug, occurredAt])
  @@index([orgSlug, detectorId])
  @@index([orgSlug, userId])
  @@index([orgSlug, agentId])
  @@index([alertId])
}


// ─────────────────────────────────────────────────────────────────────────────
// AGENTIK-SECURITY-COMPLIANCE-01 — Compliance & Governance Layer
// ─────────────────────────────────────────────────────────────────────────────

/// A piece of compliance evidence — supports or refutes a control evaluation.
/// Append-only. Never contains raw secrets.
model ComplianceEvidence {
  /// Cuid — matches ComplianceEvidence.id in domain types.
  id           String @id @default(cuid())

  /// Tenant scope — orgSlug (NOT organizationId FK).
  orgSlug      String

  /// ID of the ComplianceControl being evidenced (e.g. "CTRL_MFA").
  controlId    String

  /// EvidenceSource: AUDIT_LOG | RBAC | MFA | VAULT | KMS | ZERO_TRUST | ANOMALY_DETECTION | SECRET_ROTATION | MANUAL | SYSTEM
  source       String

  /// True if this evidence supports compliance; false = gap/violation indicator.
  isSupporting Boolean @default(true)

  /// Human-readable summary of the evidence. Never contains raw secrets.
  summary      String

  /// Serializable evidence data — never contains raw secrets, OTP, or key material.
  data         Json    @default("{}")

  /// ISO 8601 — when this evidence was collected.
  collectedAt  DateTime

  /// ISO 8601 — when this evidence expires (controls recertification windows).
  expiresAt    DateTime?

  /// Optional: actor (user/agent/system) that produced this evidence.
  actorId      String?

  /// Optional: ComplianceFramework (SOC2 | ISO27001 | GDPR | HIPAA | CUSTOM).
  framework    String?

  @@index([orgSlug])
  @@index([orgSlug, controlId])
  @@index([orgSlug, source])
  @@index([orgSlug, isSupporting])
  @@index([orgSlug, collectedAt])
  @@index([controlId])
}

/// A compliance finding — the result of evaluating one control for one org.
/// Captures status, score, violations, evidence references, and remediations.
model ComplianceFinding {
  /// Cuid — matches ComplianceFinding.id in domain types.
  id           String @id @default(cuid())

  /// Tenant scope — orgSlug (NOT organizationId FK).
  orgSlug      String

  /// ID of the ComplianceControl evaluated.
  controlId    String

  /// Optional: ComplianceFramework context.
  framework    String?

  /// FindingType: COMPLIANT | VIOLATION | WARNING | RECOMMENDATION | NOT_EVALUATED
  type         String

  /// ComplianceStatus: COMPLIANT | PARTIAL | NON_COMPLIANT | UNKNOWN
  status       String @default("UNKNOWN")

  /// ComplianceSeverity: LOW | MEDIUM | HIGH | CRITICAL
  severity     String

  /// Human-readable title (e.g. "MFA — Partially Compliant").
  title        String

  /// Summary of findings including evidence and gap counts.
  summary      String

  /// 0–100 compliance score for this control.
  score        Int    @default(0)

  /// Array of evidence IDs supporting this finding.
  evidenceIds  Json   @default("[]")

  /// Serialized ComplianceViolation[] — inline because violations are derived.
  violations   Json   @default("[]")

  /// Ordered remediation steps.
  remediations Json   @default("[]")

  /// ISO 8601 — when this finding was evaluated.
  evaluatedAt  DateTime

  /// ISO 8601 — when re-evaluation is required.
  validUntil   DateTime?

  @@index([orgSlug])
  @@index([orgSlug, status])
  @@index([orgSlug, controlId])
  @@index([orgSlug, framework])
  @@index([orgSlug, severity])
  @@index([orgSlug, evaluatedAt])
  @@index([orgSlug, status, severity])
}

/// Snapshot of a control's compliance status at a point in time.
/// Used for trend analysis and recertification tracking.
model ComplianceControlStatus {
  /// Cuid.
  id          String @id @default(cuid())

  /// Tenant scope.
  orgSlug     String

  /// ID of the ComplianceControl.
  controlId   String

  /// Optional: ComplianceFramework context.
  framework   String?

  /// ComplianceStatus: COMPLIANT | PARTIAL | NON_COMPLIANT | UNKNOWN
  status      String

  /// 0–100 compliance score.
  score       Int    @default(0)

  /// ISO 8601 — when this snapshot was taken.
  evaluatedAt DateTime

  /// ISO 8601 — when this snapshot expires.
  validUntil  DateTime?

  @@index([orgSlug])
  @@index([orgSlug, controlId])
  @@index([orgSlug, status])
  @@index([orgSlug, evaluatedAt])
}

// ── Memory Graph ──────────────────────────────────────────────────────────────

model MemoryGraphNode {
  /// Stable ID generated by graph-identity.ts (mgn_ prefix).
  id        String @id

  /// Tenant scope — always required.
  orgSlug   String

  /// GraphNodeType: MEMORY | CLIENT | PRODUCT | ORDER | ...
  nodeType  String

  /// Human-readable label for this node.
  label     String

  /// Arbitrary serializable metadata.
  metadata  Json   @default("{}")

  /// Provenance — which system created this node.
  source    String

  /// Semantic tags.
  tags      String[]

  /// Importance weight 0–1.
  weight    Float  @default(0.5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgSlug])
  @@index([orgSlug, nodeType])
  @@index([orgSlug, createdAt])
  @@index([weight])
}

model MemoryGraphEdge {
  /// Stable ID generated by graph-identity.ts (mge_ prefix).
  id           String @id

  /// Tenant scope — always required.
  orgSlug      String

  /// GraphEdgeType: RELATED_TO | GENERATED_BY | CAUSES | ...
  edgeType     String

  /// Source node ID.
  sourceNodeId String

  /// Target node ID.
  targetNodeId String

  /// Relationship strength 0–1.
  weight       Float  @default(0.5)

  /// Optional human label for this relationship.
  label        String?

  /// Arbitrary metadata.
  metadata     Json   @default("{}")

  /// Provenance — which system created this edge.
  source       String

  /// Why does this relationship exist? Required for traceability.
  reasoning    String?

  createdAt    DateTime @default(now())

  @@index([orgSlug])
  @@index([orgSlug, edgeType])
  @@index([orgSlug, sourceNodeId])
  @@index([orgSlug, targetNodeId])
  @@index([sourceNodeId, targetNodeId])
  @@index([orgSlug, createdAt])
}

/// --------------------
/// Cross-Module Reasoning
/// AGENTIK-INTELLIGENCE-CROSS-MODULE-REASONING-01
