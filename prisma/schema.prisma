// ── Reconciliation Sessions (AGENTIK-RECON-SESSIONS-01) ───────────────────────

/// A reconciliation session is one auditable reconciliation operation.
/// Example: RC-2026-00041 · Banco Bogotá vs Cobros SAG · Abril 2026
///
/// Sessions are durable: they contain runs, audit events, and summary snapshots.
/// Individual record-level results are NOT stored here — only summaries.
///
/// Tenant safety: organizationId is required on every row. All queries must
/// include organizationId in the WHERE clause.
model ReconciliationSession {
  id             String             @id @default(cuid())
  organizationId String
  /// Human-readable code: RC-YYYY-##### (e.g. RC-2026-00041)
  sessionCode    String
  title          String
  /// Source type slugs matching ReconciliationSourceType in source-contract.ts
  sourceAType    String
  sourceALabel   String
  sourceBType    String
  sourceBLabel   String
  /// "YYYYMM" period — null for date-range sessions
  period         String?
  status         ReconSessionStatus @default(DRAFT)
  /// userId or "system"
  createdBy      String?
  /// userId of assigned operator
  assignedTo     String?
  startedAt      DateTime?
  completedAt    DateTime?
  closedAt       DateTime?
  /// ReconSummary snapshot after last completed run
  summaryJson    Json?
  /// Extra context: source configs, filters, run parameters
  metadataJson   Json?

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  runs         ReconciliationRun[]
  events       ReconciliationEvent[]
  exceptions   ReconciliationException[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, sessionCode])
  @@index([organizationId, status])
  @@index([organizationId, period])
  @@index([organizationId, createdAt])
}

/// One execution of a reconciliation session.
/// Sessions can have multiple runs (retries, reruns after source correction).
/// Individual record results are NOT stored — only the summary snapshot.
model ReconciliationRun {
  id             String @id @default(cuid())
  organizationId String
  sessionId      String
  /// Increments per session: 1, 2, 3, ...
  runNumber      Int    @default(1)
  /// "pending" | "running" | "completed" | "failed" | "unsupported"
  status         String @default("pending")
  sourceAKey     String?
  sourceBKey     String?
  period         String?
  /// ReconSummary JSON when status = "completed"
  summaryJson    Json?
  /// Error details when status = "failed"
  errorJson      Json?
  /// Performance metrics + shadow config snapshot for this run (RECON-ENGINE-03)
  metadataJson   Json?
  startedAt      DateTime?
  completedAt    DateTime?

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  session      ReconciliationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exceptions   ReconciliationException[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

/// Immutable audit trail for reconciliation sessions.
/// Every meaningful action emits one event — events are never modified or deleted.
///
/// actorType: "system" | "user" | "agent"
/// eventType: see ReconAuditEventType in session-types.ts
model ReconciliationEvent {
  id             String @id @default(cuid())
  organizationId String
  sessionId      String
  /// "system" | "user" | "agent"
  actorType      String @default("system")
  /// userId, agentId, or null for system events
  actorId        String?
  /// See ReconAuditEventType in session-types.ts
  eventType      String
  message        String
  metadataJson   Json?

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  session      ReconciliationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([organizationId, eventType])
  @@index([organizationId, createdAt])
}

/// Persisted reconciliation exception from a run.
/// Created by the engine persistence layer (AGENTIK-RECON-ENGINE-03).
/// Resolution state updated by operators via the Exception Resolution Workbench.
///
/// recordKey: matches WorkbenchException.recordKey — deterministic per record+type pair
/// type: mismatch_amount | only_in_a | only_in_b | duplicate_in_a | duplicate_in_b | probable_match
/// severity: info | watch | elevated | critical
/// status: open | under_review | resolved | ignored
model ReconciliationException {
  id             String @id @default(cuid())
  organizationId String
  sessionId      String
  runId          String
  /// Deterministic key — matches WorkbenchException.recordKey
  recordKey      String
  /// Exception type (see WorkbenchExceptionType)
  type           String
  /// Severity: info | watch | elevated | critical
  severity       String @default("info")
  /// Amounts from source A and source B
  amountA        Float?
  amountB        Float?
  /// Delta: amountB - amountA
  delta          Float?
  /// Delta as percentage of amountA
  deltaPercent   Float?
  /// Row counts from each source for this key
  rowsA          Int    @default(1)
  rowsB          Int    @default(1)
  /// Resolution lifecycle: open → under_review → resolved | ignored
  status         String @default("open")
  resolution     String?
  resolvedBy     String?
  resolvedAt     DateTime?
  /// Explanation text, reasons[], and engine metadata snapshot
  metadataJson   Json?

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  session      ReconciliationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  run          ReconciliationRun     @relation(fields: [runId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([runId])
  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([organizationId, severity])
  @@index([recordKey])
}

/// ─────────────────────────────────────────────────────────────────────────
/// ReconExecution — Persisted result of a configurable rule-engine run.
///
/// AGENTIK-RECON-SESSION-PERSISTENCE-01
///
/// Distinct from ReconciliationRun (legacy engine) — ReconExecution is
/// produced by the rule-engine/run API route using the configurable rule set
/// and the new Record Loader Registry.
///
/// Design principles:
///   - No full record sets stored — only metrics and the ExecutionReport JSON.
///   - sessionId is an unvalidated reference (no FK) for cross-querying.
///   - Immutable after creation — no updates, only new rows.
///   - All metric fields are top-level for efficient filtering/sorting.
/// ─────────────────────────────────────────────────────────────────────────

model ReconExecution {
  id             String   @id @default(cuid())
  organizationId String
  /// Optional: links to a ReconciliationSession (unvalidated reference, not FK)
  sessionId      String?
  /// Actor who triggered the run — userId or "system"
  triggeredBy    String?

  // ── Timing ──────────────────────────────────────────────────────────────
  startedAt   DateTime
  finishedAt  DateTime?
  durationMs  Int?

  // ── Source identity ──────────────────────────────────────────────────────
  sourceAType  String
  sourceBType  String
  sourceALabel String
  sourceBLabel String
  period       String

  // ── Loader provenance ────────────────────────────────────────────────────
  loaderA              String
  loaderB              String
  normalizationVersion String?

  // ── Record counts ────────────────────────────────────────────────────────
  recordsA Int @default(0)
  recordsB Int @default(0)

  // ── Pipeline metrics ─────────────────────────────────────────────────────
  pairsEvaluated   Int @default(0)
  pairsReconciled  Int @default(0)
  pairsPartial     Int @default(0)
  pairsMismatch    Int @default(0)
  pairsSuspicious  Int @default(0)
  pairsPending     Int @default(0)
  pairsNoCandidate Int @default(0)

  // ── Scoring ──────────────────────────────────────────────────────────────
  avgScore  Int @default(0)
  maxScore  Int @default(0)
  minScore  Int @default(0)
  matchRate Int @default(0) /// 0–100

  // ── Rule configuration ───────────────────────────────────────────────────
  rulesTotal   Int @default(0)
  rulesEnabled Int @default(0)

  // ── Lifecycle ────────────────────────────────────────────────────────────
  /// "completed" | "failed" | "no_records" | "pending_source"
  status String @default("completed")

  // ── Full ExecutionReport JSON ─────────────────────────────────────────────
  executionReportJson Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, sourceAType, sourceBType])
  @@index([organizationId, period])
  @@index([organizationId, sessionId])
  @@index([organizationId, status])
}

/// ─────────────────────────────────────────────────────────────────────────
/// ReconReviewItem — One actionable item produced by the rule engine.
///
/// AGENTIK-RECON-REVIEW-CENTER-01
///
/// Created for every pair whose verdict is partial | pending_review |
/// mismatch | suspicious (and reconciled with low confidence).
///
/// Design principles:
///   - Immutable identity fields (executionId, recordKeys, verdict)
///   - Mutable lifecycle fields (status, assignedTo, reviewNote, resolution)
///   - All status transitions emit a ReconReviewAuditEvent
///   - No full record datasets — only keys, score, and explainability
/// ─────────────────────────────────────────────────────────────────────────

model ReconReviewItem {
  id             String   @id @default(cuid())
  organizationId String

  // ── Execution linkage ────────────────────────────────────────────────────
  /// ID from ExecutionReport — string key, not FK to ReconExecution
  executionId    String
  /// Optional: links to a ReconciliationSession
  sessionId      String?

  // ── Source identity ──────────────────────────────────────────────────────
  sourceAType    String
  sourceBType    String

  // ── Record keys (immutable identity) ────────────────────────────────────
  recordAKey     String
  /// Null when there is no candidate in source B
  recordBKey     String?

  // ── Engine output (immutable) ────────────────────────────────────────────
  score          Int      @default(0)
  /// "reconciled" | "partial" | "mismatch" | "suspicious" | "pending_review" | "no_candidate"
  verdict        String
  verdictLabel   String
  /// One-line human explanation
  headline       String
  /// Full explainability JSON from buildRuleExplanation()
  explanationJson Json?

  // ── Lifecycle ────────────────────────────────────────────────────────────
  /// "open" | "in_review" | "resolved" | "dismissed" | "escalated"
  status         String   @default("open")
  assignedTo     String?
  reviewNote     String?
  /// "approved" | "rejected" | "manual_match" | "needs_sag_validation"
  ///   | "needs_business_validation" | "needs_bank_support"
  resolution     String?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  auditEvents    ReconReviewAuditEvent[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, executionId])
  @@index([organizationId, status])
  @@index([organizationId, verdict])
  @@index([organizationId, sourceAType, sourceBType])
  @@index([organizationId, sessionId])
  @@index([organizationId, createdAt])
}

/// ─────────────────────────────────────────────────────────────────────────
/// ReconReviewAuditEvent — Immutable audit trail for review item transitions.
///
/// Every status change, resolution, note, or assignment creates one row.
/// Never updated — append-only.
/// ─────────────────────────────────────────────────────────────────────────

model ReconReviewAuditEvent {
  id             String   @id @default(cuid())
  organizationId String

  reviewItemId   String
  reviewItem     ReconReviewItem @relation(fields: [reviewItemId], references: [id], onDelete: Cascade)

  /// Actor: userId string or "system"
  actor          String
  /// "status_changed" | "resolved" | "assigned" | "note_added" | "escalated"
  eventType      String
  previousStatus String?
  newStatus      String?
  resolution     String?
  note           String?
  /// Any extra context (ruleIds, sourceKeys, etc.)
  metadataJson   Json?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())

  @@index([organizationId, reviewItemId])
  @@index([organizationId, createdAt])
}

/// --------------------
/// Agentik Financial Copilot V1
/// --------------------

/// Audit record for every signal surfaced by the Copilot engine.
/// Immutable — never update, only insert.
model CopilotSignalRecord {
  id             String   @id @default(cuid())
  organizationId String

  /// Which rule fired: budget.velocity_exceeded | treasury.low_coverage | etc.
  ruleId         String
  /// Severity at time of detection: critica | elevada | vigilancia | informativa
  severity       String
  /// Lifecycle state: detected | visible | acknowledged | dismissed | resolved
  lifecycle      String   @default("detected")
  /// Target module: planeacion | tesoreria | cierre | conciliacion
  targetModule   String
  /// Signal title (human-readable, snapshot)
  titulo         String

  /// Confidence score 0–100
  confidenceScore   Int
  confidenceLevel   String  // ALTA | MEDIA | BAJA | BASADA_EN_REGLA

  /// Full evidence JSON snapshot for auditability
  evidenceJson   Json?
  /// Explainability text (Level 1 template)
  explicacion    String?

  detectedAt     DateTime @default(now())
  expiresAt      DateTime?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// Actions taken on this signal
  actions        CopilotActionLog[]

  @@index([organizationId, ruleId])
  @@index([organizationId, lifecycle])
  @@index([organizationId, targetModule])
  @@index([organizationId, detectedAt])
}

/// Audit trail for every action taken in response to a Copilot signal.
/// Records who acted, on which signal, and what the outcome was.
model CopilotActionLog {
  id             String   @id @default(cuid())
  organizationId String

  /// Signal that triggered this action (nullable — some actions are direct)
  signalId       String?
  /// Rule that originated the signal
  ruleId         String
  /// Module where the action was taken
  module         String
  /// Action taken: acknowledged | dismissed | navigated | resolved | escalated
  action         String
  /// User identifier (email or userId)
  actorId        String
  /// Optional outcome description
  outcome        String?
  /// Snapshot of entity state at action time
  entitySnapshot Json?

  createdAt      DateTime @default(now())

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  signal         CopilotSignalRecord? @relation(fields: [signalId], references: [id], onDelete: SetNull)

  @@index([organizationId, ruleId])
  @@index([organizationId, actorId])
  @@index([signalId])
}

// ─── MS-05F: Product Intelligence Layer (Hardened) ───────────────────────────
//
// Identity convention:
//   • All rows use `organizationId` — never `orgId` or `tenantId`.
//   • Organization IS the tenant; tenantId is not stored separately.
//   • String fields replace Prisma enums to avoid migration lock-in;
//     valid values are governed at the domain layer (product-enums.ts).
// ─────────────────────────────────────────────────────────────────────────────

/// The authoritative commercial product entity.
/// Created when an operator approves a GeneratedAsset through the Biblioteca.
/// One ProductEntity may link to many assets (hero, gallery, swatch, …).
model ProductEntity {
  id             String  @id @default(cuid())
  organizationId String

  /// Optimistic concurrency — incremented on every meaningful mutation.
  version        Int     @default(1)

  /// ── Commercial identity ──
  name             String
  sku              String?
  category         String?
  description      String?
  price            Float?
  currency         String  @default("COP")

  /// Lifecycle — domain values in ProductStatus enum
  status           String  @default("pending")
  /// Commercial lifecycle — domain values in CommercialStatus enum
  commercialStatus String  @default("active")
  /// Usage rights — domain values in UsagePermission enum
  usagePermission  String  @default("commercial")

  /// ── CRM enrichment ──
  crmName       String?
  productLine   String?
  segment       String?
  salesArgument String?
  availability  String?
  notes         String?

  /// ── Persisted readiness snapshot ──
  /// Updated by persistReadinessSnapshot() after any metadata/attribute change.
  /// Avoids on-demand recomputation at read time.
  readinessLevel          String    @default("not_ready")
  readinessScore          Int       @default(0)
  readyDestinations       Json?     // String[] — channel names that are ready
  partialDestinations     Json?     // String[] — channel names that are partial
  blockedDestinations     Json?     // String[] — channel names that are blocked
  lastReadinessComputedAt DateTime?

  /// ── Audit ──
  approvedAt DateTime?
  approvedBy String?   // userId of the approver

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  organization      Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  variants          ProductVariant[]
  attributes        ProductAttribute[]
  assetLinks        ProductAssetLink[]
  syncStates        ProductSyncState[]
  publicationStates ProductPublicationState[]
  propagationJobs   PropagationJob[]
  activity          ProductActivity[]

  @@index([organizationId, status])
  @@index([organizationId, sku])
  @@index([organizationId, category])
  @@index([organizationId, readinessLevel])
  @@index([organizationId, createdAt])
}

/// A size / color / format variant of a ProductEntity.
model ProductVariant {
  id             String   @id @default(cuid())
  productId      String
  organizationId String
  sku            String?
  name           String
  /// domain values: active | inactive | discontinued
  status         String   @default("active")
  /// Discriminating attribute key-value snapshot for this variant
  attributes     Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product        ProductEntity @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([organizationId, productId])
}

/// A typed dynamic attribute attached to a ProductEntity.
/// Supports text, number, boolean, and JSON (multiselect) value types.
model ProductAttribute {
  id             String   @id @default(cuid())
  productId      String
  organizationId String
  key            String
  label          String
  valueText      String?
  valueNumber    Float?
  valueBoolean   Boolean?
  valueJson      Json?    // used for multiselect (String[])
  /// domain values: text | number | boolean | select | multiselect | dimension | color
  type           String   @default("text")
  /// Target channel for this attribute (null = applies to all channels)
  destination    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product        ProductEntity @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, key])
  @@index([productId])
  @@index([organizationId, key])
}

/// Junction: links a GeneratedAsset to a ProductEntity with a semantic role.
/// Carries full provenance metadata for analytics, cost attribution,
/// regeneration, and Luca optimization.
model ProductAssetLink {
  id             String   @id @default(cuid())
  productId      String
  organizationId String
  /// GeneratedAsset.id
  assetId        String
  /// domain values: hero | gallery | swatch | video | document
  role           String   @default("gallery")

  /// ── Provenance ──
  /// How the asset was created: ai_generated | manual_upload | external
  sourceType           String?
  /// ID of the GeneratedAsset session or batch that produced this asset
  sourceGenerationId   String?
  /// Which product/provider produced this asset: foto_estudio | external | manual
  sourceProvider       String?
  /// userId or agent identifier responsible for the generation
  generatedBy          String?
  /// Strategic intent at generation time: hero | variant | catalog | ad
  generationIntent     String?

  createdAt      DateTime @default(now())

  product        ProductEntity @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, assetId])
  @@index([productId])
  @@index([organizationId, assetId])
}

/// Per-channel sync state for a ProductEntity (one row per product × channel).
/// Tracks the DATA synchronization lifecycle — distinct from publication lifecycle.
model ProductSyncState {
  id             String    @id @default(cuid())
  productId      String
  organizationId String
  /// domain values: shopify | crm | whatsapp | catalog | ads | landing
  channel        String
  /// domain values: pending | synced | failed | outdated | not_configured
  status         String    @default("pending")
  lastSyncAt     DateTime?
  errorMessage   String?
  /// ID of the record in the destination system after sync
  externalId     String?
  /// Monotonic version — matches ProductEntity.version at sync time
  version        Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  product        ProductEntity @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, channel])
  @@index([productId])
  @@index([organizationId, channel, status])
}

/// Per-channel publication state for a ProductEntity (one row per product × channel).
/// Tracks PUBLICATION lifecycle — separate from sync/data lifecycle.
///
/// Example: shopify may be synced (data current) but unpublished (not live).
/// whatsapp may be published but the catalog listing is outdated.
model ProductPublicationState {
  id                       String    @id @default(cuid())
  productId                String
  organizationId           String
  /// domain values: shopify | crm | whatsapp | catalog | ads | landing
  channel                  String
  /// domain values: unpublished | published | scheduled | paused | archived
  publicationStatus        String    @default("unpublished")
  publishedAt              DateTime?
  lastPublicationAttemptAt DateTime?
  /// ID assigned by the destination system upon publication
  externalPublicationId    String?
  /// URL of the published listing (if applicable)
  publicationUrl           String?
  errorMessage             String?
  /// Monotonic version — incremented on each publication attempt
  version                  Int       @default(1)
  /// ── Shopify-specific fields (MS-11) ──────────────────────────────────────
  /// Shopify product handle (e.g. "camiseta-azul-marino")
  shopifyHandle            String?
  /// Map of Agentik variantId → Shopify variantId (JSON object)
  externalVariantIds       Json?
  /// Timestamp of last successful data sync with Shopify
  lastSyncAt               DateTime?

  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  product                  ProductEntity @relation(fields: [productId], references: [id], onDelete: Cascade)
  publicationEvents        CommercePublicationEvent[]

  @@unique([productId, channel])
  @@index([productId])
  @@index([organizationId, channel, publicationStatus])
}

/// Durable audit log for every publication lifecycle event for a product × channel.
/// Append-only — never updated, never deleted.
model CommercePublicationEvent {
  id                 String   @id @default(cuid())
  organizationId     String
  productId          String
  channel            String
  publicationStateId String

  /// Event type: queued | publishing_started | published | failed | retrying | partial | archived
  eventType          String
  /// Final state after this event
  resultState        String
  /// CommerceJob that triggered this event (nullable for manual/system events)
  jobId              String?
  /// Safe summary — no tokens, no secrets
  message            String?
  /// Shopify-specific result payload (externalId, handle, variantIds) — server-side only
  payload            Json?

  occurredAt         DateTime @default(now())

  publicationState   ProductPublicationState @relation(fields: [publicationStateId], references: [id], onDelete: Cascade)

  @@index([organizationId, productId, channel])
  @@index([publicationStateId])
  @@index([organizationId, eventType, occurredAt])
}

/// Durable propagation job queue.
/// Created when product metadata changes and channels need re-sync.
/// Processed by the sync engine (MS-05C+). Not executed here.
model PropagationJob {
  id             String    @id @default(cuid())
  organizationId String
  productId      String
  /// ProductEventType that triggered this job
  eventType      String
  /// Target channel for propagation
  channel        String
  /// domain values: pending | running | completed | failed | cancelled
  status         String    @default("pending")
  /// 1 = highest priority, 10 = lowest
  priority       Int       @default(5)
  /// Event-specific payload for the worker
  payload        Json?
  scheduledAt    DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  retryCount     Int       @default(0)
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  product        ProductEntity @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, scheduledAt])
  @@index([productId])
  @@index([organizationId, channel, status])
}

/// Immutable audit event for a ProductEntity.
/// Feeds the activity timeline (MS-05E) and Luca/Mila intelligence (MS-05D).
model ProductActivity {
  id             String   @id @default(cuid())
  productId      String
  organizationId String
  /// ProductEventType — e.g. PRODUCT_CREATED, PRODUCT_APPROVED, …
  eventType      String
  /// Typed payload — structure governed by product-event-payloads.ts
  payload        Json?
  actorId        String?
  actorLabel     String?
  occurredAt     DateTime @default(now())

  product        ProductEntity @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, occurredAt])
  @@index([organizationId, eventType])
}

/// ──────────────────────────────────────────────────────────────────────
/// MS-10 — Integration Runtime Models
/// ──────────────────────────────────────────────────────────────────────

/// Live OAuth/API connection between an org and an external provider.
/// Replaces the blob-based Integration.secretsJson pattern for commerce channels.
/// Secrets are stored in IntegrationSecret, never here.
model IntegrationConnection {
  id             String   @id @default(cuid())
  organizationId String

  /// Provider key: shopify | meta | tiktok | whatsapp | google | custom
  provider       String
  /// Status: not_connected | connected | expired | revoked | error | disabled
  status         String   @default("not_connected")
  /// Health: healthy | warning | critical | disconnected
  health         String   @default("disconnected")

  /// Shopify-specific: the myshopify.com domain
  shopDomain     String?

  /// External account info (safe — no secrets)
  externalAccountId   String?
  externalAccountName String?
  /// Multi-account fields — AGENTIK-OAUTH-CONNECTIONS-01
  label               String?
  isPrimary           Boolean  @default(false)
  accountHandle       String?
  accountAvatarUrl    String?
  accountType         String?
  providerGroup       String?
  externalPageId      String?
  externalBusinessId  String?
  externalAdAccountId String?
  /// Granted OAuth scopes as JSON array of strings
  scopes         Json     @default("[]")

  connectedAt       DateTime?
  disconnectedAt    DateTime?
  lastHealthCheckAt DateTime?
  errorMessage      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  secrets      IntegrationSecret[]
  events       IntegrationEvent[]
  commerceJobs CommerceJob[]

  @@index([organizationId])
  @@index([organizationId, provider])
  @@index([organizationId, provider, externalAccountId])
  @@index([organizationId, status])
  @@index([provider, status])
}

/// Encrypted secret per connection × secret type.
/// V1: AES-256-GCM with VAULT_ENCRYPTION_KEY.
/// V2+: swap to KMS envelope encryption without schema change.
/// NEVER expose encryptedValue to client layers.
model IntegrationSecret {
  id             String   @id @default(cuid())
  organizationId String
  connectionId   String

  /// Secret type: access_token | refresh_token | api_key | webhook_secret | hmac_key
  secretType     String
  /// AES-256-GCM encrypted value: base64(iv):base64(authTag):base64(ciphertext)
  encryptedValue String
  /// Encryption key version — used for rotation tracking
  keyVersion     String   @default("v1")

  expiresAt  DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connection   IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([organizationId, connectionId, secretType])
  @@index([connectionId, secretType])
  @@index([expiresAt])
}

/// Immutable audit trail for integration lifecycle events.
/// Payloads must never contain token values or secrets.
model IntegrationEvent {
  id             String   @id @default(cuid())
  organizationId String
  connectionId   String?
  provider       String

  /// Event type — see INTEGRATION_EVENT_TYPE in integration-events.ts
  eventType String
  /// Safe payload — no secrets
  payload   Json   @default("{}")
  actorId   String?
  occurredAt DateTime @default(now())

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connection   IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([organizationId, provider, occurredAt])
  @@index([connectionId, occurredAt])
  @@index([organizationId, eventType])
}

/// Incoming webhook events from external providers.
/// Stored before processing for deduplication and replay protection.
model IntegrationWebhookEvent {
  id             String   @id @default(cuid())
  organizationId String
  provider       String

  /// Provider-assigned webhook ID (used for deduplication)
  eventId  String
  topic    String
  /// Full raw webhook payload
  payload  Json

  /// Status: pending | processed | failed
  status       String    @default("pending")
  errorMessage String?
  processedAt  DateTime?
  receivedAt   DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider, eventId])
  @@index([organizationId, provider, status])
  @@index([organizationId, receivedAt])
}

/// Async commerce sync job — created by the publication queue, executed by MS-11/MS-13.
/// One job = one product × one channel action.
/// MS-13: connectionId is nullable to support internal jobs (catalog, readiness).
model CommerceJob {
  id             String  @id @default(cuid())
  organizationId String
  /// Nullable: internal jobs (catalog.rebuild, product.recompute_readiness) have no integration connection
  connectionId   String?

  provider  String
  /// Job type: publish_product_draft | update_product | delete_product | sync_inventory | sync_collection
  /// MS-13: shopify.publish_draft | shopify.sync_check | catalog.rebuild | product.recompute_readiness | etc.
  jobType   String
  /// Status: pending | queued | running | succeeded | failed | cancelled | retry_scheduled | skipped | pending_external
  status    String  @default("pending")
  /// Lower number = higher priority (1 = urgent, 10 = low)
  priority  Int     @default(5)

  /// Target product (nullable for non-product jobs)
  productId      String?
  /// Target catalog (nullable)
  catalogId      String?
  /// Idempotency key — prevents duplicate jobs for the same operation
  idempotencyKey String? @unique
  /// Max retry attempts before permanent failure
  maxRetries     Int     @default(3)

  /// Typed job payload
  payload Json  @default("{}")
  /// Result payload from the provider (set on completion)
  result  Json?

  retryCount  Int       @default(0)
  scheduledAt DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  lastError   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization  Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connection    IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  retryAttempts ExecutionRetryAttempt[]

  @@index([organizationId, provider, status])
  @@index([organizationId, status, scheduledAt])
  @@index([organizationId, jobType, status])
  @@index([connectionId, status])
  @@index([productId])
  @@index([idempotencyKey])
}

/// Persistent destination health snapshot — recorded by MS-13 execution worker
model DestinationHealthSnapshot {
  id              String   @id @default(cuid())
  organizationId  String
  destination     String
  healthLevel     String   @default("unknown")
  failedJobCount  Int      @default(0)
  pendingJobCount Int      @default(0)
  staleCount      Int      @default(0)
  webhookBacklog  Int      @default(0)
  isAuthValid     Boolean  @default(true)
  detail          String?
  snapshotAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, destination, snapshotAt(sort: Desc)])
  @@index([organizationId, snapshotAt(sort: Desc)])
}

/// Audit trail for each retry attempt on a CommerceJob (MS-13)
model ExecutionRetryAttempt {
  id             String    @id @default(cuid())
  organizationId String
  jobId          String
  attemptNumber  Int
  scheduledAt    DateTime
  executedAt     DateTime?
  /// succeeded | failed | skipped
  outcome        String?
  errorMessage   String?
  createdAt      DateTime  @default(now())

  job          CommerceJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([organizationId, createdAt(sort: Desc)])
}

/// Content variant per product × channel — tracks format/ratio readiness for distribution
model DistributionVariant {
  id             String   @id @default(cuid())
  organizationId String
  productId      String?
  assetId        String?
  /// feed | story | reel | ad | catalog | whatsapp | hero | thumbnail | collection_cover | landing_banner
  purpose        String
  /// shopify | instagram | facebook | tiktok | whatsapp | ads | catalog | landing | email
  channel        String
  /// "1:1" | "9:16" | "16:9" | "4:5"
  ratio          String?
  width          Int?
  height         Int?
  isReady        Boolean  @default(false)
  sourceAssetUrl String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, productId])
  @@index([organizationId, channel, purpose])
  @@index([organizationId, isReady])
}

/// Coordinated multi-channel distribution pipeline for a product set or collection
model DistributionPipeline {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  /// new_collection_launch | whatsapp_drop | campaign_launch | evergreen_rotation | seasonal_release | recovery_campaign
  pipelineType   String
  /// draft | active | running | completed | failed | paused
  status         String    @default("draft")
  /// JSON string[] — channel names included in this pipeline
  channels       Json      @default("[]")
  /// JSON stage definitions
  stages         Json      @default("[]")
  /// JSON string[] — productIds covered
  productIds     Json      @default("[]")
  catalogId      String?
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([organizationId, pipelineType])
  @@index([organizationId, scheduledAt])
}

/// Scheduled distribution slot — defines when content drops to a channel
model DistributionSchedule {
  id             String    @id @default(cuid())
  organizationId String
  label          String
  /// immediate | scheduled | recurring | launch_window | campaign_sequence
  slotType       String
  channel        String
  timezone       String    @default("America/Bogota")
  scheduledAt    DateTime?
  recurrenceCron String?
  /// JSON string[] — productIds for this slot
  productIds     Json      @default("[]")
  pipelineId     String?
  /// pending | active | completed | cancelled | missed
  status         String    @default("pending")
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, channel, status])
  @@index([organizationId, scheduledAt])
}

/// Unified Publishing Plan — coordinates multi-channel publication for a product/campaign/catalog
model PublishingPlan {
  id                 String    @id @default(cuid())
  organizationId     String
  campaignId         String?
  productId          String?
  catalogId          String?
  /// draft | planned | blocked | queued | preparing | publishing | published | partial | failed | retrying | cancelled | archived
  status             String    @default("draft")
  /// critical | high | medium | low
  priority           String    @default("medium")
  /// manual | schedule | campaign | distribution_pipeline | product_approved | catalog_updated | retry | webhook
  trigger            String    @default("manual")
  /// JSON summary of destination states
  destinationSummary Json      @default("{}")
  /// 0–100
  progress           Int       @default(0)
  scheduledAt        DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  steps        PublishingPlanStep[]
  events       PublishingEvent[]

  @@index([organizationId, status])
  @@index([organizationId, scheduledAt])
  @@index([organizationId, priority])
}

/// One publishing step within a PublishingPlan — targets a single destination
model PublishingPlanStep {
  id             String    @id @default(cuid())
  organizationId String
  planId         String
  /// shopify | instagram | facebook | tiktok | whatsapp | youtube | landing | catalog | ads | email
  destination    String
  /// draft | planned | blocked | queued | preparing | publishing | published | partial | failed | retrying | cancelled | archived
  status         String    @default("draft")
  /// JSON array of PublishingDependency
  dependencies   Json      @default("[]")
  /// JSON payload for execution
  payload        Json      @default("{}")
  executionJobId String?
  retryCount     Int       @default(0)
  lastError      String?
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         PublishingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([organizationId, planId])
  @@index([organizationId, destination, status])
  @@index([organizationId, scheduledAt])
}

/// Immutable event log for publishing plan lifecycle
model PublishingEvent {
  id             String   @id @default(cuid())
  organizationId String
  planId         String?
  stepId         String?
  /// publishing.plan_created | publishing.step_queued | publishing.step_started | etc.
  eventType      String
  payload        Json     @default("{}")
  occurredAt     DateTime @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         PublishingPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([organizationId, eventType])
  @@index([organizationId, planId])
  @@index([organizationId, occurredAt])
}

/// Point-in-time health snapshot for the Publishing OS
model PublishingHealthSnapshot {
  id             String   @id @default(cuid())
  organizationId String
  /// healthy | degraded | blocked | critical
  health         String
  summary        Json     @default("{}")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

/// Receipt emitted by a channel operator after dispatch
model OperatorReceipt {
  id             String   @id @default(cuid())
  organizationId String
  /// shopify | social | whatsapp | catalog | ads | email | landing
  channel        String
  /// dispatch | publish | sync | prepare | retry | cancel
  action         String
  /// pending | dispatched | confirmed | failed | partial
  status         String   @default("pending")
  /// external reference (Shopify product ID, Post SID, etc.)
  externalRef    String?
  /// execution job that was created
  executionJobId String?
  planId         String?
  stageId        String?
  /// operator-specific result payload
  resultPayload  Json     @default("{}")
  errorCode      String?
  errorMessage   String?
  retryCount     Int      @default(0)
  durationMs     Int?
  dispatchedAt   DateTime @default(now())
  confirmedAt    DateTime?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, channel, status])
  @@index([organizationId, planId])
  @@index([organizationId, dispatchedAt])
}

/// Immutable audit trail for all operator actions
model OperatorAuditEvent {
  id             String   @id @default(cuid())
  organizationId String
  channel        String
  action         String
  /// actor who triggered (user ID or "system")
  actorId        String?
  receiptId      String?
  planId         String?
  stageId        String?
  payload        Json     @default("{}")
  occurredAt     DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, channel])
  @@index([organizationId, occurredAt])
}

/// Point-in-time health snapshot per operator channel
model OperatorHealthSnapshot {
  id             String   @id @default(cuid())
  organizationId String
  channel        String
  /// healthy | degraded | unavailable | unknown
  health         String
  successRate    Float    @default(0)
  avgDurationMs  Int      @default(0)
  totalDispatched Int     @default(0)
  totalFailed     Int     @default(0)
  summary        Json     @default("{}")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, channel, createdAt])
}

/// ──────────────────────────────────────────────────────────────────────
/// AGENTIK-INTEGRATIONS-VAULT-RUNTIME-01 — OAuth Session
/// ──────────────────────────────────────────────────────────────────────

/// Short-lived OAuth state session — created when user initiates connect flow,
/// consumed on callback, expired after 10 minutes.
/// Never stores tokens — only PKCE state and scope intent.
model OAuthSession {
  id             String   @id @default(cuid())
  organizationId String

  /// Provider: tiktok | meta | shopify | google
  provider       String
  /// CSRF / state parameter — must match callback exactly
  state          String   @unique
  /// PKCE code verifier (S256 method)
  codeVerifier   String?
  /// Redirect URI used when building the authorization URL
  redirectUri    String
  /// Scopes requested as JSON array of strings
  requestedScopes Json    @default("[]")
  /// Status: pending | consumed | expired | failed
  status         String   @default("pending")
  /// Opaque metadata (e.g. returnTo URL, user agent)
  metadata       Json     @default("{}")

  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, provider, status])
  @@index([state])
  @@index([expiresAt])
}

/// ──────────────────────────────────────────────────────────────────────
/// AGENTIK-BANKING-FOUNDATION-01 — Banking Domain
/// ──────────────────────────────────────────────────────────────────────

/// A bank account belonging to an organization.
/// Opening/current/available balances are maintained by banking-balances runtime.
model BankAccount {
  id                  String   @id @default(cuid())
  organizationId      String
  /// Human-friendly label set by the user
  accountName         String
  bankName            String
  /// Last 4 digits or masked format: ****1234
  accountNumberMasked String?
  /// checking | savings | investment | petty_cash
  accountType         String   @default("checking")
  /// ISO 4217: COP | USD | EUR
  currency            String   @default("COP")
  /// active | inactive | closed
  status              String   @default("active")
  /// Balance at account opening (initial seed)
  openingBalance      Float    @default(0)
  /// Last computed book balance (sum of all movements)
  currentBalance      Float    @default(0)
  /// currentBalance minus pending/uncommitted items
  availableBalance    Float    @default(0)
  lastMovementAt      DateTime?
  lastSyncAt          DateTime?
  /// Arbitrary metadata (IBAN, Swift, branch, etc.)
  metadata            Json     @default("{}")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization  Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  movements     BankMovement[]
  syncSessions  BankSyncSession[]
  reconciliations BankReconciliation[]

  @@index([organizationId, status])
  @@index([organizationId, lastSyncAt])
}

/// A single debit or credit movement on a BankAccount.
/// Source of truth for cash balance computation.
model BankMovement {
  id                  String   @id @default(cuid())
  organizationId      String
  bankAccountId       String
  movementDate        DateTime
  /// Free-text from bank statement
  description         String?
  /// Bank-issued transaction reference (for dedup / matching)
  reference           String?
  /// Absolute value — direction determines sign
  amount              Float
  /// credit | debit
  direction           String
  /// Balance on the account after this movement (from bank statement)
  balanceAfter        Float?
  /// manual | csv_import | excel_import | api_sync | api_future
  source              String   @default("manual")
  /// FACTURA | RECIBO_CAJA | CONSIGNACION | EGRESO | ANTICIPO | DESCONOCIDO
  sourceDocumentType  String?
  /// Counterpart document reference (SAG comprobante, invoice number, etc.)
  sourceDocumentRef   String?
  /// Whether this movement has been matched to a graph node
  matched             Boolean  @default(false)
  matchedAt           DateTime?
  /// Financial graph node ID if matched
  graphNodeId         String?
  /// Raw import payload (CSV row, API response, etc.)
  rawPayload          Json     @default("{}")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bankAccount     BankAccount          @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  reconciliations BankReconciliation[]

  @@index([organizationId, bankAccountId, movementDate])
  @@index([organizationId, matched])
  @@index([organizationId, reference])
  @@index([bankAccountId, movementDate])
}

/// A sync session capturing one import/reconciliation run for a BankAccount.
model BankSyncSession {
  id             String    @id @default(cuid())
  organizationId String
  bankAccountId  String
  /// manual | csv_import | excel_import | api_sync
  source         String
  /// pending | running | completed | failed | partial
  status         String    @default("pending")
  /// Date range of imported statement
  fromDate       DateTime?
  toDate         DateTime?
  importedCount  Int       @default(0)
  duplicateCount Int       @default(0)
  unresolvedCount Int      @default(0)
  matchedCount   Int       @default(0)
  errorMessages  Json      @default("[]")
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bankAccount  BankAccount  @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@index([organizationId, bankAccountId, status])
  @@index([organizationId, createdAt])
}

/// A match between a BankMovement and a FinancialGraph node.
/// Records confidence, match signals, and reconciliation status.
model BankReconciliation {
  id             String   @id @default(cuid())
  organizationId String
  bankMovementId String
  bankAccountId  String
  /// FinancialGraph node ID matched against
  graphNodeId    String
  /// 0.0 – 1.0
  confidence     Float    @default(0)
  /// Fields used to match: reference | nit+amount | date+amount | etc.
  matchedBy      Json     @default("[]")
  /// pending | confirmed | rejected | under_review
  status         String   @default("pending")
  /// Human or AI explanation of the match
  explanation    String?
  /// User who confirmed/rejected (null = auto-matched)
  resolvedBy     String?
  resolvedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bankMovement BankMovement  @relation(fields: [bankMovementId], references: [id], onDelete: Cascade)
  bankAccount  BankAccount   @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([organizationId, bankMovementId])
  @@index([organizationId, graphNodeId])
}

/// Metadata record for a bank statement file uploaded by the user.
/// The actual movements are parsed and stored as BankMovement rows.
model BankStatementUpload {
  id              String   @id @default(cuid())
  organizationId  String
  bankAccountId   String?
  /// Original file name
  fileName        String
  /// csv | excel | pdf | ofx | other
  fileFormat      String   @default("csv")
  fileSize        Int?
  /// pending | processing | completed | failed
  status          String   @default("pending")
  rowsDetected    Int      @default(0)
  rowsImported    Int      @default(0)
  rowsSkipped     Int      @default(0)
  errorMessages   Json     @default("[]")
  uploadedBy      String?
  processedAt     DateTime?
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

/// Operational snapshot of the financial system at a point in time.
/// Used by the Runtime Detector Engine to compare previous vs current state.
model FinancialRuntimeSnapshot {
  id                   String   @id @default(cuid())

  organizationId       String

  generatedAt          DateTime

  /// 0–100: % of graph nodes without critical issues
  graphIntegrityPct    Float
  /// Raw count of unresolved graph relations
  unresolvedCount      Int

  /// 0–100: % of bank movements reconciled
  reconciliationHealth Float

  /// 0–1: liquidity confidence (HIGH→0.9, MEDIUM→0.6, LOW→0.2)
  liquidityConfidence  Float

  /// Number of stale data sources
  staleSources         Int

  /// Number of active close blockers
  closeBlockers        Int

  /// Whether banking data is connected and real
  bankingConnected     Boolean

  /// HEALTHY | DEGRADED | CRITICAL
  overallState         String

  createdAt            DateTime @default(now())

  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, generatedAt])
}

/// A real financial event detected by comparing runtime snapshots.
/// Events are dispatchable to n8n / webhooks / WhatsApp / email.
model FinancialRuntimeEvent {
  id                 String   @id @default(cuid())

  organizationId     String

  /// RECON_BREAK | LOW_CONFIDENCE | STALE_SOURCE | CLOSE_BLOCKER |
  /// BANK_UNMATCHED | LIQUIDITY_RISK | DIAN_STALE | SYNC_RESTORED |
  /// GRAPH_DEGRADED | GRAPH_RECOVERED
  type               String
  /// critical | warning | info
  severity           String

  title              String
  summary            String

  /// Prisma model or runtime that sourced this event
  source             String?

  /// Current confidence at time of event (0–1)
  confidence         Float?
  /// Previous confidence before this event (0–1)
  previousConfidence Float?

  /// true = ready for n8n / webhook dispatch
  eventDispatchable  Boolean  @default(true)

  createdAt          DateTime @default(now())

  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([organizationId, type])
}

// ════════════════════════════════════════════════════════════════════════════
// MALETAS COMERCIALES — Operational Persistence Models
// Sprint: AGENTIK-COMERCIAL-MALETAS-PERSISTENCE-01
// ════════════════════════════════════════════════════════════════════════════

/// Snapshot of a commercial case (vendedor × línea) at a point in time.
/// Captures the case health summary without full item-level detail.
model CommercialCase {
  id              String   @id @default(cuid())
  organizationId  String

  salesRepId      String   // internal id: "NESTOR", "ORLANDO", etc.
  salesRepName    String
  line            String   // "LT" | "CS"

  refsTotal       Int
  refsOk          Int
  refsAgotadas    Int
  refsBajoMinimo  Int
  refsEnProceso   Int

  /// 0–100 aggregate pressure score at time of snapshot
  presionOperacional Int @default(0)
  /// "bajo" | "medio" | "alto" | "critico"
  riesgoComercial    String @default("bajo")

  snapshotAt      DateTime
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, salesRepId, line])
  @@index([organizationId, snapshotAt])
  @@index([organizationId, line])
}

/// Snapshot of a single item inside a commercial case at a point in time.
/// Used for temporal evolution tracking per reference.
model CommercialCaseItem {
  id                   String   @id @default(cuid())
  organizationId       String

  reference            String
  description          String
  line                 String   // "LT" | "CS"

  currentUnits         Int
  minimumRequired      Int
  /// "ok" | "bajo_minimo" | "sin_stock" | "en_proceso" | "sobre_comprometido"
  status               String
  /// "OK" | "REPONER_MALETA" | "PRODUCIR" | "ESPERAR_LOTE" | "REVISAR"
  recommendedAction    String
  productionBatchLabel String?

  /// JSON: string[] — salesRep ids that carry this item
  assignedSalesRepIds  Json     @default("[]")

  snapshotAt           DateTime
  createdAt            DateTime @default(now())

  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, reference])
  @@index([organizationId, snapshotAt])
  @@index([organizationId, line, status])
  @@index([organizationId, reference, snapshotAt])
}

/// Coverage signal snapshot for a single reference at a point in time.
/// Primary source for temporal evolution detection and trend analysis.
model CommercialCoverageSnapshot {
  id               String   @id @default(cuid())
  organizationId   String

  refCode          String
  description      String
  line             String   // "LT" | "CS"

  disponible       Int
  dailyVelocity    Float?
  coverageDays     Float?
  /// CoverageStatus: cobertura_alta | cobertura_estable | cobertura_baja |
  /// ruptura_inminente | sin_rotacion | sin_datos_velocidad | sin_stock
  status           String
  operationalScore Int      @default(0)
  affectedRepCount Int      @default(0)

  /// SAG PD demand fields (AGENTIK-SAG-PD-DEMAND-LAYER-01)
  pendingOrdersQty   Int?   // SAG PD pending orders for this ref at snapshot time
  demandPressureScore Int?  // 0–100 combined demand pressure score

  snapshotAt       DateTime
  createdAt        DateTime @default(now())

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, refCode, snapshotAt])
  @@index([organizationId, snapshotAt])
  @@index([organizationId, status])
  @@index([organizationId, refCode])
}

/// Operational event detected by comparing consecutive maletas snapshots.
/// Source of truth for the operational timeline and copilot signals.
model CommercialOperationalEvent {
  id               String   @id @default(cuid())
  organizationId   String

  /// ruptura_inminente | cobertura_recuperada | vendedor_en_presion |
  /// linea_caliente | stock_muerto | produccion_urgente |
  /// degradacion_recurrente | recuperacion_operacional
  type             String
  /// "critical" | "warning" | "info"
  severity         String

  title            String
  body             String

  refCode          String?
  line             String?
  salesRepId       String?

  /// Serialized evidence: coverage days, trend %, refs affected, etc.
  evidence         Json     @default("{}")
  operationalImpact String?

  /// Whether this event has been dispatched to copilot / n8n / webhooks
  dispatched       Boolean  @default(false)

  createdAt        DateTime @default(now())

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([organizationId, type])
  @@index([organizationId, refCode])
  @@index([organizationId, salesRepId])
}

/// Production signal snapshot (requirement detected at a given point in time).
/// Used to track whether production signals are recurring for the same ref.
model CommercialProductionSignal {
  id                    String   @id @default(cuid())
  organizationId        String

  reference             String
  description           String
  line                  String

  /// "normal" | "importante" | "alta" | "urgente" | "critica"
  urgency               String
  priority              Int      @default(0)

  totalMissing          Int
  suggestedQty          Int
  coverageDaysRemaining Float?
  affectedSalesRepCount Int
  /// JSON: string[] — salesRep ids affected
  affectedSalesRepIds   Json     @default("[]")

  batchInProcess        Boolean  @default(false)
  batchLabel            String?
  reasoning             String

  /// SAG PD demand fields (AGENTIK-SAG-PD-DEMAND-LAYER-01)
  pendingOrdersQty      Int?    // SAG PD pending orders for this ref at snapshot time
  demandPressureScore   Int?    // 0–100 combined demand pressure score
  orderConversionPct    Int?    // % of PD orders converted to invoices in the window
  pdSourceCount         Int?    // number of distinct PD records contributing to pendingOrdersQty
  unconvertedOrderQty   Int?    // PD units with no invoice match in the analysis window

  /// Whether this production signal was resolved in a later snapshot
  resolved              Boolean  @default(false)

  snapshotAt            DateTime
  createdAt             DateTime @default(now())

  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, reference, snapshotAt])
  @@index([organizationId, urgency])
  @@index([organizationId, snapshotAt])
  @@index([organizationId, resolved])
}

/// Dead stock signal snapshot at a point in time.
/// Enables detection of refs that have been dead for multiple cycles.
model CommercialDeadStockSignal {
  id                  String   @id @default(cuid())
  organizationId      String

  refCode             String
  description         String
  line                String

  disponible          Int
  lastSaleDate        String?
  daysSinceLastSale   Int?

  /// DeadStockReason: sin_ventas_30d | cobertura_excesiva |
  /// sin_rotacion_conocida | linea_discontinuada
  reason              String
  /// DeadStockDisposal: revisar | reubicar | descontinuar
  disposalSuggestion  String
  commercialRisk      Int

  /// JSON: string[]
  assignedSalesRepIds Json     @default("[]")

  /// Whether this dead stock was cleared (sold / relocated) in a later snapshot
  resolved            Boolean  @default(false)

  snapshotAt          DateTime
  createdAt           DateTime @default(now())

  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, refCode])
  @@index([organizationId, snapshotAt])
  @@index([organizationId, resolved])
  @@index([organizationId, refCode, snapshotAt])
}

/// Full operational profile snapshot for a sales rep × line at a point in time.
/// Drives sales rep pressure trends and recurring risk detection.
model CommercialSalesRepProfileSnapshot {
  id                    String   @id @default(cuid())
  organizationId        String

  salesRepId            String
  salesRepName          String
  line                  String   // "LT" | "CS"

  refsTotal             Int
  refsOk                Int
  refsAgotadas          Int
  refsBajoMinimo        Int
  refsEnProceso         Int

  coverageAvgDays       Float?
  coverageMinDays       Float?

  presionOperacional    Int
  dependenciaProduccion Int
  dependenciaReposicion Int

  /// "bajo" | "medio" | "alto" | "critico"
  riesgoComercial       String
  riesgoScore           Int

  /// JSON: string[] — garment categories with strong velocity
  lineasFuertes         Json     @default("[]")
  /// JSON: string[] — garment categories with dead / slow velocity
  lineasDebiles         Json     @default("[]")
  /// JSON: string[] — refs with coverageDays < 7
  coverageWeakRefs      Json     @default("[]")

  snapshotAt            DateTime
  createdAt             DateTime @default(now())

  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, salesRepId, line, snapshotAt], map: "comm_srep_snap_org_rep_line_at_idx")
  @@index([organizationId, snapshotAt],                  map: "comm_srep_snap_org_at_idx")
  @@index([organizationId, salesRepId, line],             map: "comm_srep_snap_org_rep_line_idx")
}

// ── Agent Runtime — Durable Execution Lifecycle ───────────────────────────────
// Sprint: AGENTIK-AGENT-RUNTIME-DURABILITY-01
// These models persist the execution session lifecycle so that a process restart
// does not destroy in-flight execution state. They are the Prisma-mode source
// of truth; the in-memory store remains the default (AGENTIK_RUNTIME_STORE=memory).

/// Persistent record of a single tool execution session.
/// Created when an approved action is dispatched for execution.
model RuntimeExecutionSession {
  id             String    @id
  organizationId String
  actionId       String
  toolId         String
  agentId        String
  moduleKey      String?
  /// ExecutionStatus: queued|leasing|validating|running|succeeded|failed|
  ///   retry_scheduled|canceled|timed_out|skipped|rejected
  status         String
  attempt        Int       @default(0)
  maxAttempts    Int       @default(3)
  leaseOwner     String?
  leaseExpiresAt DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  canceledAt     DateTime?
  timedOutAt     DateTime?
  durationMs     Int?
  idempotencyKey String?
  correlationId  String?
  causationId    String?
  payload        Json?
  result         Json?
  /// JSON: { message: string|null, code: string|null }
  error          Json?
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  attempts     RuntimeExecutionAttempt[]
  leases       RuntimeExecutionLease[]

  @@index([organizationId, status])
  @@index([actionId])
  @@index([toolId])
  @@index([agentId])
  @@index([idempotencyKey])
  @@index([correlationId])
  @@index([leaseExpiresAt])
  @@index([organizationId, createdAt(sort: Desc)])
}

/// A single attempt within a RuntimeExecutionSession.
/// Each retry creates a new attempt record with a parent reference.
model RuntimeExecutionAttempt {
  id              String    @id
  sessionId       String
  attemptNumber   Int
  /// running|succeeded|failed|timed_out
  status          String
  parentAttemptId String?
  retryReason     String?
  startedAt       DateTime?
  completedAt     DateTime?
  durationMs      Int?
  /// JSON: { message: string|null }
  error           Json?
  retryable       Boolean   @default(false)
  nextRetryAt     DateTime?
  createdAt       DateTime  @default(now())

  session RuntimeExecutionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([status])
  @@index([nextRetryAt])
}

/// Lease held by an executor for a RuntimeExecutionSession.
/// Only one lease should be active per session at any given time.
model RuntimeExecutionLease {
  id          String    @id @default(cuid())
  sessionId   String
  ownerId     String
  /// active|released|expired|stolen
  status      String    @default("active")
  acquiredAt  DateTime
  expiresAt   DateTime
  releasedAt  DateTime?
  /// Updated on every heartbeat refresh
  heartbeatAt DateTime?
  createdAt   DateTime  @default(now())

  session RuntimeExecutionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([ownerId])
  @@index([expiresAt])
  @@index([status])
}

// ═══ VENDOR COMMERCIAL BAG SYSTEM ══════════════════════════════════════════════
// Sprint: AGENTIK-COMERCIAL-MALETAS-BLOCK-01-PERSISTENCE-ORDERS-01
//
// A VendorCommercialBag represents real inventory committed to one sales rep
// for a season. Units are consumed as orders arrive.
//
// Core invariant (enforced on every write):
//   availableToSellQty = assignedQty - soldQty
//
// Pressure chain:
//   availableToSellQty <= minQty  → status = "bajo_minimo" → CommercialOperationalEvent
//   availableToSellQty === 0      → status = "agotado"
//   2+ vendors low on same ref    → CommercialProductionSignal (source = "bag_pressure")
// ═══════════════════════════════════════════════════════════════════════════════

/// A commercial bag for one sales rep in one season.
/// Manages the lifecycle of inventory committed to that person.
/// status: borrador | activa | pausada | archivada
model VendorCommercialBag {
  id             String    @id @default(cuid())
  organizationId String

  salesRepId     String
  season         String    // "Junio 2026" | "Escolar 2026" | etc.
  startDate      DateTime?
  endDate        DateTime?

  /// borrador | activa | pausada | archivada
  status         String    @default("borrador")

  /// Free-form notes from coordinator
  notes          String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items          VendorBagItem[]
  orderLines     VendorBagOrderLine[]

  @@unique([organizationId, salesRepId, season])
  @@index([organizationId, salesRepId])
  @@index([organizationId, status])
  @@index([organizationId, season])
}

/// A single reference line within a vendor's commercial bag.
///
/// Key invariant (maintained by order-ingest-service):
///   availableToSellQty = assignedQty - soldQty
///
/// status: ok | bajo_minimo | agotado | pausado | excede_inventario
model VendorBagItem {
  id             String   @id @default(cuid())
  organizationId String
  bagId          String

  reference      String   // SAG ref code UPPERCASE
  description    String
  line           String   // "LT" | "CS"
  category       String
  productType    String

  /// Units committed from warehouse for this vendor/season
  assignedQty    Int

  /// Units sold / consumed — updated by order-ingest-service
  soldQty        Int      @default(0)

  /// assignedQty - soldQty — updated atomically with soldQty
  availableToSellQty Int

  /// Minimum before pressure is generated
  minQty         Int      @default(0)

  /// Ideal target quantity
  idealQty       Int      @default(0)

  /// Snapshot of warehouse available when item was assigned
  inventoryAvailableAtAssign Int

  /// ok | bajo_minimo | agotado | pausado | excede_inventario
  status         String   @default("ok")

  /// 1 = highest priority within the bag
  priority       Int      @default(1)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bag            VendorCommercialBag @relation(fields: [bagId], references: [id], onDelete: Cascade)
  orderLines     VendorBagOrderLine[]

  @@unique([bagId, reference])
  @@index([organizationId, bagId])
  @@index([organizationId, reference])
  @@index([organizationId, status])
  @@index([bagId, status])
}

/// Audit record of each order ingestion that consumed units from a bag item.
/// One record per order line per vendor.
/// Used for: audit trail, velocity calculation, David signal context.
model VendorBagOrderLine {
  id             String   @id @default(cuid())
  organizationId String

  bagId          String
  itemId         String
  reference      String
  salesRepId     String

  /// External order / pedido identifier
  orderRef       String?

  /// Units consumed from this bag item
  qtySold        Int

  /// Snapshot of availableToSellQty BEFORE deduction
  availableBeforeQty Int

  /// Snapshot of availableToSellQty AFTER deduction
  availableAfterQty  Int

  /// Whether this line triggered a pressure event
  triggeredPressure  Boolean @default(false)

  soldAt         DateTime
  createdAt      DateTime @default(now())

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bag            VendorCommercialBag @relation(fields: [bagId], references: [id], onDelete: Cascade)
  item           VendorBagItem       @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([organizationId, salesRepId])
  @@index([organizationId, reference])
  @@index([bagId, itemId])
  @@index([organizationId, soldAt])
  @@index([organizationId, orderRef])
}

// ─────────────────────────────────────────────────────────────────────────────
// OPERATIONAL RESERVATION SYSTEM
// Sprint: AGENTIK-OPERATIONAL-RESERVATION-ENGINE-01
//
// Agentik reserves units operationally BEFORE SAG legalizes the order.
// These records deduct from operationalAvailableQty.
// They are released/consumed/expired as the order lifecycle advances.
// ─────────────────────────────────────────────────────────────────────────────

/// Agentik operational reservation — soft hold on inventory units.
/// Lives entirely in Agentik until a confirmed order is sent to SAG as PD.
///
/// Formula impact:
///   operationalAvailableQty = physicalQty - SUM(active.qtyReserved) - salesAssignedQty - pendingTransfersQty
model OperationalReservation {
  id             String   @id @default(cuid())
  organizationId String

  /// What originated this reservation: order | portfolio | manual | transfer
  sourceType     String
  /// ID of the originating entity (orderId / portfolioId / etc.)
  sourceId       String

  salesRepId     String?
  customerId     String?

  /// SAG reference code — UPPERCASE
  reference      String
  description    String

  /// Units originally reserved
  qtyReserved    Int
  /// Units freed back to the pool (partial or full release)
  qtyReleased    Int      @default(0)
  /// Units that advanced to SAG PD (consumed)
  qtyConsumed    Int      @default(0)

  /// active | released | consumed | expired | cancelled
  status         String   @default("active")
  reason         String
  expiresAt      DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events         OperationalReservationEvent[]

  @@index([organizationId, status])
  @@index([organizationId, reference])
  @@unique([organizationId, sourceType, sourceId, reference])
  @@index([organizationId, sourceType, sourceId])
  @@index([organizationId, salesRepId])
  @@index([expiresAt])
}

/// Immutable audit record of every reservation lifecycle event.
/// One event per state transition — full traceability of inventory holds.
model OperationalReservationEvent {
  id             String   @id @default(cuid())
  organizationId String

  reservationId  String
  /// reservation.created | reservation.released | reservation.consumed |
  /// reservation.expired | reservation.cancelled | reservation.pressure_triggered
  type           String
  /// JSON payload: impact, quantities, context
  payloadJson    Json

  createdAt      DateTime @default(now())

  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reservation    OperationalReservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([organizationId, reservationId])
  @@index([organizationId, type])
  @@index([reservationId, createdAt])
}

// ─── Operational KPI Certification ───────────────────────────────────────────
//
// Persistent certification record for each operational KPI.
// Tracks the full lifecycle: draft → reviewing → validated → certified → production_ready.
//
// INTERNAL ONLY: SUPER_ADMIN / AGENTIK_ADMIN
// Sprint: AGENTIK-OPERATIONAL-KPI-CERTIFICATION-01

model OperationalKpiCertification {
  id             String   @id @default(cuid())

  organizationId String
  kpiKey         String
  domain         String

  // ── Source of truth ──────────────────────────────────────────────────────
  expectedSources Json     @default("[]")
  actualSources   Json     @default("[]")
  sourceOfTruth   String?

  // ── Connection status snapshot ───────────────────────────────────────────
  technicalStatus    String   @default("pending")
  operationalStatus  String   @default("pending")

  // ── Approval gates ───────────────────────────────────────────────────────
  businessApproved   Boolean  @default(false)
  sagApproved        Boolean  @default(false)
  productionReady    Boolean  @default(false)

  // ── Trust score ──────────────────────────────────────────────────────────
  confidenceScore    Int      @default(0)

  // ── Field-level validation flags ─────────────────────────────────────────
  queryValidated     Boolean  @default(false)
  fieldsValidated    Boolean  @default(false)
  syncValidated      Boolean  @default(false)

  // ── Validator identities ─────────────────────────────────────────────────
  validatedBy          String?
  validatedRole        String?
  sagValidatedBy       String?
  businessValidatedBy  String?

  // ── Notes ────────────────────────────────────────────────────────────────
  validationNotes  String?
  blockerNotes     String?

  // ── Approved query artifacts ─────────────────────────────────────────────
  approvedQuery    String?
  approvedTable    String?
  approvedFields   Json?

  // ── Sync telemetry ───────────────────────────────────────────────────────
  expectedSyncFrequency  String?
  realSyncFrequency      String?
  lastSyncAt             DateTime?
  lastValidatedAt        DateTime?

  // ── Lifecycle state ──────────────────────────────────────────────────────
  certificationStatus  String  @default("draft")

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, kpiKey])
  @@index([organizationId, domain])
  @@index([organizationId, certificationStatus])
  @@index([organizationId, productionReady])
}

// ─── Operational KPI Source ───────────────────────────────────────────────────
//
// One record per data source feeding a KPI. A KPI can have multiple sources
// with different roles (primary, secondary, fallback, calculated, hybrid).
//
// INTERNAL ONLY: SUPER_ADMIN / AGENTIK_ADMIN
// Sprint: AGENTIK-LIVE-KPI-CERTIFICATION-WORKSPACE-01

model OperationalKpiSource {
  id             String   @id @default(cuid())

  organizationId String
  kpiKey         String

  // ── Source identity ──────────────────────────────────────────────────────
  sourceName     String
  sourceType     String   // direct_sag | crm | bank | agentik | manual | external | calculated | hybrid
  sourceRole     String   @default("primary")  // primary | secondary | fallback | calculated | hybrid

  provider       String   // sag | crm | bank | agentik | manual | external

  // ── SAG / DB specifics ───────────────────────────────────────────────────
  tableName      String?
  approvedQuery  String?
  approvedFields Json?    // string[]
  approvedFilters Json?   // string[]

  sourceOfTruth  Boolean  @default(false)

  // ── Freshness / sync ─────────────────────────────────────────────────────
  freshnessMinutes  Int?
  expectedFrequency String?

  connectorActive   Boolean @default(false)

  // ── Validation gates ─────────────────────────────────────────────────────
  queryValidated    Boolean @default(false)
  fieldsValidated   Boolean @default(false)
  businessValidated Boolean @default(false)
  sagValidated      Boolean @default(false)

  confidenceScore   Int     @default(0)

  validatedBy  String?
  validatedAt  DateTime?

  // ── Validation lifecycle ─────────────────────────────────────────────────
  // suggested | assigned | pending_existence_validation | exists_confirmed
  // | fields_confirmed | query_confirmed | sag_confirmed | crm_confirmed
  // | business_confirmed | ready_for_integration | rejected
  validationStatus  String    @default("suggested")

  // ── Extended location ─────────────────────────────────────────────────────
  description  String?
  viewName     String?
  endpoint     String?
  moduleName   String?

  // ── Bootstrap / historical import ─────────────────────────────────────────
  // Populated when source was created by the bootstrap engine from a CSV.
  // bootstrapMetadata: { rowNumber, sagCode, sagId, originalName, classification,
  //   tipo, matchType, matchConfidence, importedAt, unresolvedFields? }
  bootstrapBatchId   String?
  bootstrapMetadata  Json?

  // ── Runtime detection (AGENTIK-SAG-RUNTIME-SOURCE-HYDRATION-01) ──────────
  // Populated when source was auto-detected from existing Prisma runtime data.
  // sourceOrigin: "runtime_detected" | "csv_bootstrap" | "manual" | "dba_confirmed"
  sourceOrigin        String?
  runtimeRowCount     Int?
  runtimeLastSyncAt   DateTime?
  runtimeConfidence   Int?
  runtimeLineage      Json?    // AGENTIK-RUNTIME-SOURCE-LINEAGE-01

  notes  String?

  // ── Source governance (AGENTIK-OPS-CERTIFICATION-GOVERNANCE-01) ─────────
  sourceContribution   String?   // what this source contributes to the KPI
  sourceTruthPriority  String?   // PRIMARY | SECONDARY | ENRICHMENT | VALIDATION | FALLBACK
  viewType             String?   // consolidated | fuente_1 | fuente_2 | tiendas | web

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, kpiKey])
  @@index([organizationId, sourceType])
  @@index([organizationId, provider])
  @@index([organizationId, validationStatus])
}

// ─── Operational KPI Definition ───────────────────────────────────────────────
//
// User-created KPI definitions not in the static registry.
// Enables "New KPI" workflow during SAG meetings.
//
// INTERNAL ONLY: SUPER_ADMIN / AGENTIK_ADMIN
// Sprint: AGENTIK-LIVE-KPI-CERTIFICATION-WORKSPACE-01

model OperationalKpiDefinition {
  id             String   @id @default(cuid())

  organizationId String
  kpiKey         String   // unique within org — slug-style

  domain         String
  entityLabel    String
  kpiDefinition  String

  priority       String   @default("medium")  // critical | high | medium | low
  frequency      String   @default("daily")

  sourceOfTruth  String?
  formula        String?

  // ── Governance fields (AGENTIK-OPS-CERTIFICATION-GOVERNANCE-01) ─────────
  formulaExpression    String?   // e.g. "stock_disponible / venta_promedio_30d"
  formulaDescription   String?   // human-readable explanation of the formula
  businessDefinition   String?   // business-level definition of the KPI
  dependencyType       String?   // SAG_ONLY | AGENTIK_ONLY | HYBRID | CRM | MANUAL | EXTERNAL
  criticality          String?   @default("OPERATIONAL")  // CRITICAL | OPERATIONAL | INFORMATIONAL | EXPERIMENTAL
  sagContributions     Json?     @default("[]")   // string[] — what SAG provides
  agentikContributions Json?     @default("[]")   // string[] — what Agentik computes

  expectedSources Json    @default("[]")  // string[]
  affectedModules Json    @default("[]")  // string[]

  ownerTechnical  String?
  ownerBusiness   String?
  ownerSag        String?

  notes  String?

  createdBy  String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, kpiKey])
  @@index([organizationId, domain])
}

// ─── Operational KPI Event ────────────────────────────────────────────────────
//
// Immutable append-only timeline of every certification lifecycle event.
// Powers the operational timeline view inside the certification drawer.
//
// INTERNAL ONLY: SUPER_ADMIN / AGENTIK_ADMIN
// Sprint: AGENTIK-LIVE-KPI-CERTIFICATION-WORKSPACE-01

model OperationalKpiEvent {
  id             String   @id @default(cuid())

  organizationId String
  kpiKey         String

  // ── Event identity ───────────────────────────────────────────────────────
  eventType  String
  // kpi_created | kpi_updated | review_started |
  // technical_approved | business_approved | sag_approved |
  // certified | production_ready | blocked | revoked | deprecated |
  // source_added | source_updated | source_confirmed |
  // query_saved | fields_confirmed | note_added

  actorId    String
  actorName  String?
  actorRole  String?

  description  String
  metadata     Json?   // any extra context for the event

  createdAt  DateTime  @default(now())

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, kpiKey])
  @@index([organizationId, createdAt])
  @@index([organizationId, eventType])
}

// ─── Operational Data Source Catalog ─────────────────────────────────────────
//
// Reusable catalog of known data sources per org.
// Enables source picker in Meeting Mode and drawer Sources tab.
// Sources here are AVAILABLE sources; assignments live in OperationalKpiSource.
//
// INTERNAL ONLY: SUPER_ADMIN / AGENTIK_ADMIN
// Sprint: AGENTIK-MEETING-SOURCE-MAPPING-01

model OperationalDataSource {
  id             String   @id @default(cuid())

  organizationId String

  provider    String   // sag | crm | agentik | bank | shopify | manual | external
  sourceType  String   // table | view | api | query | module | file | engine | custom

  name        String   // internal identifier (e.g. "sag_pedidos", "crm_aos_quotes")
  label       String   // display label (e.g. "SAG PEDIDOS / PD")
  description String?

  system      String?  // e.g. "SAG", "SugarCRM", "Agentik", "Bancolombia"

  // ── Connection specifics ─────────────────────────────────────────────────────
  tableName   String?
  viewName    String?
  endpoint    String?
  fields      Json?    // string[] — known/relevant fields
  filters     Json?    // string[] — default filters to apply

  owner       String?  // who maintains this source

  status      String   @default("active")  // active | deprecated | unknown

  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider, name])
  @@index([organizationId, provider])
  @@index([organizationId, sourceType])
}

// ─── Meeting Agreements ───────────────────────────────────────────────────────
//
// Persistent record of agreements made during SAG × Agentik validation meetings.
// Captured live during meetings; survives browser close; queryable for audits.
//
// Sprint: AGENTIK-MEETING-NOTES-PERSISTENCE-01

model MeetingAgreement {
  id             String   @id @default(cuid())
  organizationId String

  meetingType    String   // "sag_validation" | "sag_integration" | "partner" | etc.
  meetingDate    String   // ISO date "YYYY-MM-DD"

  // ── Método de integración ────────────────────────────────────────────────
  metodoIntegracion        String?  // "vistas_sql" | "replica" | "api" | "export" | "otro"
  metodoDescripcion        String?
  metodoRestricciones      String?
  metodoAccesoHistorico    String?  // method for historical data access (the main blocker)

  // ── Fuentes oficiales ────────────────────────────────────────────────────
  fuenteVentas             String?
  fuentePagos              String?
  fuenteRecaudos           String?
  fuenteCartera            String?
  fuentesNotas             String?

  // ── Sincronización ───────────────────────────────────────────────────────
  frecuenciaSincronizacion String?  // "tiempo_real" | "horaria" | "diaria" | "manual"
  horaEjecucion            String?
  syncNotas                String?

  // ── Responsables ─────────────────────────────────────────────────────────
  responsableSag           String?
  rolSag                   String?
  responsableAgentik       String?
  rolAgentik               String?
  proximaReunion           String?

  // ── Plan de acción ───────────────────────────────────────────────────────
  accionesJson             Json?    // ActionItem[]

  // ── Observaciones ────────────────────────────────────────────────────────
  observaciones            String?

  // ── Meta ─────────────────────────────────────────────────────────────────
  createdBy                String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

