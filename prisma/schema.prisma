/// CRM quote product lines — AOS_Products_Quotes.
/// One row per product line in an AOS_Quotes record.
/// Populated by pullQuoteLines() called during quote sync.
/// Without these lines, OperationalOrder.lines = [] and demand signals are blind.
model CRMQuoteLine {
  id              String    @id @default(cuid())
  organizationId  String

  // CRM source identity
  crmId           String?   // V8 record UUID from AOS_Products_Quotes
  quoteId         String?   // FK to CRMQuote.id (Prisma internal)
  quoteCrmId      String?   // CRMQuote.crmId (CRM UUID) for fast lookup

  // Product identity
  productCrmId    String?   // product_id from AOS_Products_Quotes
  reference       String    // name — the SKU/code shown to user
  productName     String?   // display name if different from reference

  // Quantities and pricing
  qty             Decimal   @db.Decimal(12, 3)
  unitPrice       Decimal   @db.Decimal(18, 2) @default(0)
  listPrice       Decimal   @db.Decimal(18, 2) @default(0)
  totalPrice      Decimal   @db.Decimal(18, 2) @default(0)
  discount        Decimal   @db.Decimal(10, 4) @default(0)
  discountAmount  Decimal   @db.Decimal(18, 2) @default(0)
  vatRate         Decimal   @db.Decimal(10, 4) @default(0)
  vatAmount       Decimal   @db.Decimal(18, 2) @default(0)

  // Castillitos custom fields
  size            String?   // talla_c
  color           String?   // color_c
  warehouseName   String?   // bodega_c
  warehouseId     String?   // adm_bodega_id_c

  // Line status
